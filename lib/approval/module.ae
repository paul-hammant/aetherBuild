arg(_ctx: ptr, value: string) {
    if map.has(_ctx, "args") == 0 {
        _e1 = map.put(_ctx, "args", list.new())
    }
    args_v, _ = map.get(_ctx, "args")
    _e2 = list.add(args_v, value)
}

arg_env(_ctx: ptr, name: string) {
