// approval — non-interactive go/no-go checks against external systems.
//
// The first backend is Jira. It queries one issue over REST and fails the
// target if required status/labels/fields are not present. It does not
// pause for a human and does not own approval workflow state.

import build
import std.string
import std.io
import std.os
import std.file
import std.fs
import std.list
import std.map
import std.path
import std.cryptography

// --- DSL setters ---

base_url(_ctx: ptr, url: string) {
    _e = map.put(_ctx, "base_url", url)
}

issue(_ctx: ptr, key: string) {
    _e = map.put(_ctx, "issue", key)
}

token_env(_ctx: ptr, name: string) {
    _e = map.put(_ctx, "token_env", name)
}

require_status(_ctx: ptr, status: string) {
    _e = map.put(_ctx, "require_status", status)
}

require_label(_ctx: ptr, label: string) {
    if map.has(_ctx, "require_labels") == 0 {
        _e1 = map.put(_ctx, "require_labels", list.new())
    }
    labels, _ = map.get(_ctx, "require_labels")
    _e2 = list.add(labels, label)
}

require_field(_ctx: ptr, field: string, value: string) {
    if map.has(_ctx, "require_fields") == 0 {
        _e1 = map.put(_ctx, "require_fields", list.new())
    }
    fields, _ = map.get(_ctx, "require_fields")
    entry = string.concat(field, "\t")
    entry = string.concat(entry, value)
    _e2 = list.add(fields, entry)
}

evidence(_ctx: ptr, path_value: string) {
    _e = map.put(_ctx, "evidence", path_value)
}

timeout(_ctx: ptr, seconds: string) {
    _e = map.put(_ctx, "timeout", seconds)
}

subject(_ctx: ptr, value: string) {
    _e = map.put(_ctx, "subject", value)
}

subject_env(_ctx: ptr, name: string) {
    _e = map.put(_ctx, "subject_env", name)
