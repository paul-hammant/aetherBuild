import build
import rust

main() {
    b = build.start()
    // Depend on all member .build.ae files so they generate Cargo.toml first
    build.dep(b, "crates/greeter/.build.ae")
    build.dep(b, "crates/cli/.build.ae")
    // Then run cargo test across the whole workspace
    rust.test_workspace(b)
}
