// Minimal C integration test for aeb's lib/c.
//
// Two .c sources under src/, linked into one native binary. Proves
// lib/c.program: glob source expansion, per-TU compile, link, and
// the cross-platform compiler/suffix defaults from build._host_os().

import build
import c
import c (sources, cflag, output_file)

main() {
    b = build.start()
    c.program(b) {
        sources("src/*.c")
        cflag("-O2")
        cflag("-Wall")
        output_file("c-hello")
    }
}
