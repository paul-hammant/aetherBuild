# Build artifacts
**/target/
**/.aeb/
**/.scala-build/
**/.*.generated.csproj
**/*.egg-info/
**/.pytest_cache/
**/.pyproject.generated.toml

# Upstream repos — fetched by fetch-upstream.sh, not committed.
# Everything inside is ignored, then our aeb files are un-ignored with !
nx-examples/**
spring-data-examples/**
clojure-multiproject-example/**
scala-cli-multi-module-demo/**
dotnet-architecture-eShopOnWeb/**

# aeb files we DO track (un-ignore)
!**/.build.ae
!**/.tests.ae
!**/.dist.ae
!**/*.bom.ae
!**/*.deps.ae
!**/*.config.ae
!**/AEB_MIGRATION_STATUS.md
!**/git-ls-files.txt

