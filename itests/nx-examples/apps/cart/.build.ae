import build
import build (dep, load_third_party_deps)
import ts
import ts (skip_lib_check, tsconfig)

main() {
    b = build.start()
    load_third_party_deps(b, "../../react.deps.ae")
    dep(b, "libs/cart/cart-page/.build.ae")
    dep(b, "libs/shared/header/.build.ae")
    dep(b, "libs/shared/styles/.build.ae")
    ts.tsc(b) {
        tsconfig("tsconfig.app.json")
        skip_lib_check()
    }
}
