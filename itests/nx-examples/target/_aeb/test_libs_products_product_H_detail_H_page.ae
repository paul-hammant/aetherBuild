import build
import build (dep, load_deps_file)
import ts

test_libs_products_product_H_detail_H_page(s: ptr) {
    b = build.begin(s, "test:libs/products/product-detail-page")
    if b == 0 { return 0 }
    dep(b, "libs/products/product-detail-page")
    load_deps_file(b, "../../../angular.deps.ae")
    ts.jest_project(b)
}
