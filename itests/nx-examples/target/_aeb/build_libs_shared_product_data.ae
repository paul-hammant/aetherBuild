import build
import build (dep, load_deps_file)
import ts
import ts (skip_lib_check)

build_libs_shared_product_data(s: ptr) {
    b = build.begin(s, "libs/shared/product/data")
    if b == 0 { return 0 }
    load_deps_file(b, "../../../../base.deps.ae")
    dep(b, "libs/shared/product/types")
    ts.tsc(b) {
        skip_lib_check()
    }
}
