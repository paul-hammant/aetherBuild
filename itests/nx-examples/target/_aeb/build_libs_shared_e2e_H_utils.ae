import build
import build (dep, load_deps_file)
import ts
import ts (skip_lib_check)

build_libs_shared_e2e_H_utils(s: ptr) {
    b = build.begin(s, "libs/shared/e2e-utils")
    if b == 0 { return 0 }
    load_deps_file(b, "../../../base.deps.ae")
    ts.tsc_project(b) {
        skip_lib_check()
    }
}
