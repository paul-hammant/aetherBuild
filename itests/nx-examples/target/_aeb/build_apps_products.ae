import build
import build (dep, load_deps_file)
import ts
import ts (skip_lib_check, tsconfig)

build_apps_products(s: ptr) {
    b = build.begin(s, "apps/products")
    if b == 0 { return 0 }
    load_deps_file(b, "../../angular.deps.ae")
    dep(b, "libs/products/home-page")
    dep(b, "libs/products/product-detail-page")
    dep(b, "libs/shared/header")
    dep(b, "libs/shared/styles")
    ts.ngc_project(b) {
        tsconfig("tsconfig.app.json")
        skip_lib_check()
    }
}
