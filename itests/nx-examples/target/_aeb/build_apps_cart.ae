import build
import build (dep, load_deps_file)
import ts
import ts (skip_lib_check, tsconfig)

build_apps_cart(s: ptr) {
    b = build.begin(s, "apps/cart")
    if b == 0 { return 0 }
    load_deps_file(b, "../../react.deps.ae")
    dep(b, "libs/cart/cart-page")
    dep(b, "libs/shared/header")
    dep(b, "libs/shared/styles")
    ts.tsc(b) {
        tsconfig("tsconfig.app.json")
        skip_lib_check()
    }
}
