import build
import dotnet
import dotnet (root_namespace, test_project, nuget)

main() {
    b = build.start()
    build.dep(b, "src/Infrastructure")
    build.dep(b, "tests/UnitTests")
    dotnet.build_project(b) {
        root_namespace("Microsoft.eShopWeb.IntegrationTests")
        test_project()
        nuget("Microsoft.EntityFrameworkCore.InMemory")
        nuget("Microsoft.NET.Test.Sdk")
        nuget("NSubstitute")
        nuget("NSubstitute.Analyzers.CSharp")
        nuget("xunit")
        nuget("xunit.runner.visualstudio")
    }
}
