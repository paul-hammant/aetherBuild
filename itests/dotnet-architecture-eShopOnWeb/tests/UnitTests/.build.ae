import build
import dotnet
import dotnet (root_namespace, nullable, implicit_usings, test_project, nuget)

main() {
    b = build.start()
    build.dep(b, "src/ApplicationCore/.build.ae")
    build.dep(b, "src/Web/.build.ae")
    dotnet.build_project(b) {
        root_namespace("Microsoft.eShopWeb.UnitTests")
        nullable()
        implicit_usings()
        test_project()
        nuget("Microsoft.NET.Test.Sdk")
        nuget("NSubstitute")
        nuget("NSubstitute.Analyzers.CSharp")
        nuget("xunit")
        nuget("xunit.runner.visualstudio")
        nuget("xunit.runner.console")
    }
}
