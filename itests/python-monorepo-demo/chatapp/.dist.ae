import build
import python
import python (package_name, version, requires_python, pip, packages_where, packages_include)

main() {
    b = build.start()
    build.dep(b, "chatapp/contentbuilder")
    python.package(b) {
        package_name("chatapp")
        version("0.1.0")
        requires_python(">=3.10")
        pip("setuptools>=70,<81")
        packages_where("..")
        packages_include("chatapp*")
    }
}
