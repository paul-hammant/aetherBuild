import build
import rust

main() {
    b = build.start()
    // Depend on all member .build.ae files so they generate their Cargo.toml first
    build.dep(b, "crates/lib/.build.ae")
    build.dep(b, "crates/cli/.build.ae")
    build.dep(b, "crates/server/.build.ae")
    // Then run cargo check across the whole workspace
    rust.check_workspace(b)
}
