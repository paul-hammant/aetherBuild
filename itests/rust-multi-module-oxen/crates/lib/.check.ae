import build
import rust
import rust (crate_name)

main() {
    b = build.start()
    build.dep(b, "crates/lib/.build.ae")
    build.dep(b, "crates/cli/.build.ae")
    build.dep(b, "crates/server/.build.ae")
    rust.check(b) {
        crate_name("import rust (crate_name, edition, ws_dep)")
    }
}
