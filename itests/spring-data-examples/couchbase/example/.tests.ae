import build
import build (dep)
import maven (load_bom_file)
import java
import java (release, source_layout, enable_preview, test_timeout)

main() {
    b = build.start()
    dep(b, "couchbase/example/.build.ae")
    load_bom_file(b, "../../spring-boot.bom.ae")
    dep(b, "org.springframework.boot:spring-boot-starter-test")
    dep(b, "org.junit.platform:junit-platform-console")
    dep(b, "couchbase/util/.build.ae")
    java.javac_test(b) {
        release("25")
        source_layout("maven idiomatic")
        enable_preview()
    }
    java.junit5(b) {
        test_timeout("30")
        enable_preview()
    }
}
