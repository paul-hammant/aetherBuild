import build
import build (dep)
import maven (load_bom_file)
import java
import java (release, source_layout, enable_preview, test_timeout)

main() {
    b = build.start()
    dep(b, "jdbc/mybatis/.build.ae")
    load_bom_file(b, "../../spring-boot.bom.ae")
    dep(b, "org.springframework.boot:spring-boot-starter-test")
    dep(b, "org.springframework.boot:spring-boot-data-jdbc-test")
    dep(b, "org.junit.platform:junit-platform-console")
    dep(b, "org.mybatis.spring.boot:mybatis-spring-boot-starter-test:3.0.4")
    dep(b, "org.springframework.boot:spring-boot-data-jdbc-test")
    java.javac_test(b) {
        release("25")
        source_layout("maven idiomatic")
        enable_preview()
    }
    java.junit5(b) {
        test_timeout("30")
        enable_preview()
    }
}
