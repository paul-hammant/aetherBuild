#!/bin/bash
# aeb — Aether Build runner
# Scans .build.ae and .tests.ae files, extracts deps, generates a single
# linked program, runs it. One process, one map, no subprocess coordination.
set -eo pipefail

AETHER="${AETHER:-ae}"
AEB_HOME="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(pwd)"

# --- shipped modules (update this list when adding new SDKs) ---
SHIPPED_MODULES=(build java kotlin gomod rust ts)

# --- argument parsing ---
TARGET=""
FORCE_DIST=0

if [[ "${1:-}" == "--init" ]]; then
    mkdir -p "$ROOT/lib"

    for mod in "${SHIPPED_MODULES[@]}"; do
        target="$AEB_HOME/lib/$mod"
        link="$ROOT/lib/$mod"
        if [[ -L "$link" ]]; then
            existing="$(readlink "$link")"
            if [[ "$existing" == "$target" ]]; then
                echo "  ok: lib/$mod"
            else
                rm "$link"
                ln -s "$target" "$link"
                echo "  updated: lib/$mod → $target"
            fi
        elif [[ -e "$link" ]]; then
            echo "  skip: lib/$mod (exists and is not a symlink)"
        else
            ln -s "$target" "$link"
            echo "  linked: lib/$mod → $target"
        fi
    done

    # update .gitignore
    gitignore="$ROOT/.gitignore"
    marker="# aetherBuild modules"
    if [[ -f "$gitignore" ]] && grep -qF "$marker" "$gitignore"; then
        echo "  .gitignore already configured"
    else
        {
            echo ""
            echo "$marker"
            for mod in "${SHIPPED_MODULES[@]}"; do
                echo "lib/$mod"
            done
        } >> "$gitignore"
        echo "  updated .gitignore"
    fi

    echo "aetherBuild initialized."
    exit 0
fi

# Parse remaining args
while [[ $# -gt 0 ]]; do
    case "$1" in
        --dist) FORCE_DIST=1; shift ;;
        *) TARGET="$1"; shift ;;
    esac
done

# --- Encode module path to C-safe function name ---
# / → _    _ → __
encode_name() {
    echo "$1" | sed 's/__/\x00/g; s|/|_|g; s/\x00/__/g'
}

# --- Scan for .build.ae and .tests.ae files ---
declare -A BUILD_DEPS    # module_dir → deps (from .build.ae)
declare -A BUILD_BODY    # module_dir → body (from .build.ae)
declare -A TEST_DEPS     # module_dir → deps (from .tests.ae)
declare -A TEST_BODY     # module_dir → body (from .tests.ae)
declare -A DIST_BODY     # module_dir → body (from .dist.ae)
BUILD_MODULES=()
TEST_MODULES=()
DIST_MODULES=()

for build_file in $(find . -name '.build.ae' -not -path './target/*' -not -path './lib/*' | sort); do
    dir=$(dirname "$build_file")
    module_dir="${dir#./}"
    BUILD_MODULES+=("$module_dir")
    BUILD_DEPS["$module_dir"]="$(grep -oP '(?<=dep\(b, ")[^"]+' "$build_file" 2>/dev/null || true)"
    BUILD_BODY["$module_dir"]="$(sed -n '/build\.start/,/^}/{ /build\.start/d; /^}/d; p; }' "$build_file")"
done

for dist_file in $(find . -name '.dist.ae' -not -path './target/*' -not -path './lib/*' | sort); do
    dir=$(dirname "$dist_file")
    module_dir="${dir#./}"
    DIST_MODULES+=("$module_dir")
    DIST_BODY["$module_dir"]="$(sed -n '/build\.start/,/^}/{ /build\.start/d; /^}/d; p; }' "$dist_file")"
done

for test_file in $(find . -name '.tests.ae' -not -path './target/*' -not -path './lib/*' | sort); do
    dir=$(dirname "$test_file")
    module_dir="${dir#./}"
    TEST_MODULES+=("$module_dir")
    TEST_DEPS["$module_dir"]="$(grep -oP '(?<=dep\(b, ")[^"]+' "$test_file" 2>/dev/null || true)"
    TEST_BODY["$module_dir"]="$(sed -n '/build\.start/,/^}/{ /build\.start/d; /^}/d; p; }' "$test_file")"
done

if [ ${#BUILD_MODULES[@]} -eq 0 ] && [ ${#TEST_MODULES[@]} -eq 0 ]; then
    echo "No .build.ae or .tests.ae files found"
    exit 0
fi

# --- Topological sort (build modules only, tests come after) ---
declare -A VISITED
SORTED_BUILD=()

visit() {
    local mod="$1"
    if [[ "${VISITED[$mod]}" == "done" ]]; then return; fi
    if [[ "${VISITED[$mod]}" == "visiting" ]]; then
        echo "error: circular dependency involving $mod" >&2
        exit 1
    fi
    VISITED["$mod"]="visiting"
    for dep in ${BUILD_DEPS[$mod]}; do
        if [[ -n "${BUILD_BODY[$dep]+x}" ]]; then
            visit "$dep"
        fi
    done
    VISITED["$mod"]="done"
    SORTED_BUILD+=("$mod")
}

for mod in "${BUILD_MODULES[@]}"; do
    visit "$mod"
done

# --- Target filtering ---
if [[ -n "$TARGET" ]]; then
    # Strip trailing slash
    TARGET="${TARGET%/}"

    # Collect transitive build deps of a module
    declare -A NEEDED_BUILD
    collect_build_deps() {
        local mod="$1"
        if [[ -n "${NEEDED_BUILD[$mod]+x}" ]]; then return; fi
        NEEDED_BUILD["$mod"]=1
        for dep in ${BUILD_DEPS[$mod]}; do
            if [[ -n "${BUILD_BODY[$dep]+x}" ]]; then
                collect_build_deps "$dep"
            fi
        done
    }

    # Auto-detect: what kind of target is this?
    IS_TEST=0
    IS_BUILD=0
    IS_DIST=0
    [[ -n "${TEST_BODY[$TARGET]+x}" ]] && IS_TEST=1
    [[ -n "${BUILD_BODY[$TARGET]+x}" ]] && IS_BUILD=1
    [[ -n "${DIST_BODY[$TARGET]+x}" ]] && IS_DIST=1

    if [[ $IS_TEST -eq 0 && $IS_BUILD -eq 0 && $IS_DIST -eq 0 ]]; then
        echo "error: no .build.ae, .tests.ae, or .dist.ae found for $TARGET" >&2
        exit 1
    fi

    if [[ $IS_TEST -eq 1 ]]; then
        # Test target: build its deps, then run the test
        for dep in ${TEST_DEPS[$TARGET]}; do
            if [[ -n "${BUILD_BODY[$dep]+x}" ]]; then
                collect_build_deps "$dep"
            fi
        done
        FILTERED_BUILD=()
        for mod in "${SORTED_BUILD[@]}"; do
            if [[ -n "${NEEDED_BUILD[$mod]+x}" ]]; then
                FILTERED_BUILD+=("$mod")
            fi
        done
        SORTED_BUILD=("${FILTERED_BUILD[@]}")
        TEST_MODULES=("$TARGET")
        DIST_MODULES=()
    elif [[ $FORCE_DIST -eq 1 && $IS_DIST -eq 1 ]]; then
        # Explicit --dist: build + package
        collect_build_deps "$TARGET"
        FILTERED_BUILD=()
        for mod in "${SORTED_BUILD[@]}"; do
            if [[ -n "${NEEDED_BUILD[$mod]+x}" ]]; then
                FILTERED_BUILD+=("$mod")
            fi
        done
        SORTED_BUILD=("${FILTERED_BUILD[@]}")
        DIST_MODULES=("$TARGET")
        TEST_MODULES=()
    else
        # Build target + deps
        collect_build_deps "$TARGET"
        FILTERED_BUILD=()
        for mod in "${SORTED_BUILD[@]}"; do
            if [[ -n "${NEEDED_BUILD[$mod]+x}" ]]; then
                FILTERED_BUILD+=("$mod")
            fi
        done
        SORTED_BUILD=("${FILTERED_BUILD[@]}")
        TEST_MODULES=()
        DIST_MODULES=()
    fi
fi

# --- Generate the combined .ae file ---
GEN_FILE="$ROOT/target/_ae_build_all.ae"
mkdir -p "$ROOT/target"

# Collect unique imports from all build/test/dist files
declare -A ALL_IMPORTS
ALL_IMPORTS["import build"]=1
for f in $(find . \( -name '.build.ae' -o -name '.tests.ae' -o -name '.dist.ae' \) -not -path './target/*' -not -path './lib/*' | sort); do
    while IFS= read -r line; do
        ALL_IMPORTS["$line"]=1
    done < <(grep '^import ' "$f" 2>/dev/null)
done

> "$GEN_FILE"
while IFS= read -r imp; do
    echo "$imp" >> "$GEN_FILE"
done < <(printf '%s\n' "${!ALL_IMPORTS[@]}" | sort)
echo "" >> "$GEN_FILE"

# Generate build functions (compile targets)
for mod in "${SORTED_BUILD[@]}"; do
    fname="build_$(encode_name "$mod")"
    body="${BUILD_BODY[$mod]}"

    dep_calls=""
    for dep in ${BUILD_DEPS[$mod]}; do
        if [[ -n "${BUILD_BODY[$dep]+x}" ]]; then
            dep_fname="build_$(encode_name "$dep")"
            dep_calls="$dep_calls    ${dep_fname}(s)
"
        fi
    done

    cat >> "$GEN_FILE" << FUNC
${fname}(s: ptr) {
${dep_calls}    ptr b = build.begin(s, "${mod}")
    if b == 0 { return 0 }
${body}
    build.done(s, "${mod}")
    return 0
}

FUNC
done

# Generate test functions — deps call build_ functions
for mod in "${TEST_MODULES[@]}"; do
    fname="test_$(encode_name "$mod")"
    body="${TEST_BODY[$mod]}"

    # Test deps call the BUILD function of the dep (compile it first)
    dep_calls=""
    for dep in ${TEST_DEPS[$mod]}; do
        if [[ -n "${BUILD_BODY[$dep]+x}" ]]; then
            dep_fname="build_$(encode_name "$dep")"
            dep_calls="$dep_calls    ${dep_fname}(s)
"
        fi
    done

    cat >> "$GEN_FILE" << FUNC
${fname}(s: ptr) {
${dep_calls}    ptr b = build.begin(s, "${mod}")
    if b == 0 { return 0 }
${body}
    build.done(s, "${mod}")
    return 0
}

FUNC
done

# Generate dist functions — call sibling build first, then dist body
for mod in "${DIST_MODULES[@]}"; do
    fname="dist_$(encode_name "$mod")"
    body="${DIST_BODY[$mod]}"

    # Dist always depends on its sibling compile
    dep_calls=""
    if [[ -n "${BUILD_BODY[$mod]+x}" ]]; then
        dep_fname="build_$(encode_name "$mod")"
        dep_calls="    ${dep_fname}(s)
"
    fi

    cat >> "$GEN_FILE" << FUNC
${fname}(s: ptr) {
${dep_calls}    ptr b = build.begin(s, "dist:${mod}")
    if b == 0 { return 0 }
${body}
    build.done(s, "dist:${mod}")
    return 0
}

FUNC
done

# Generate main()
cat >> "$GEN_FILE" << 'MAIN_START'
main() {
    ptr s = build.session(aether_args_get(1))
MAIN_START

# Build all compile targets first
for mod in "${SORTED_BUILD[@]}"; do
    fname="build_$(encode_name "$mod")"
    echo "    ${fname}(s)" >> "$GEN_FILE"
done

# Then dist
for mod in "${DIST_MODULES[@]}"; do
    fname="dist_$(encode_name "$mod")"
    echo "    ${fname}(s)" >> "$GEN_FILE"
done

# Then run all tests
for mod in "${TEST_MODULES[@]}"; do
    fname="test_$(encode_name "$mod")"
    echo "    ${fname}(s)" >> "$GEN_FILE"
done

cat >> "$GEN_FILE" << 'MAIN_END'
}
MAIN_END

echo "aeb: ${#SORTED_BUILD[@]} compile + ${#DIST_MODULES[@]} dist + ${#TEST_MODULES[@]} test"
for mod in "${SORTED_BUILD[@]}"; do
    echo "  compile: $mod"
done
for mod in "${DIST_MODULES[@]}"; do
    echo "  dist:    $mod"
done
for mod in "${TEST_MODULES[@]}"; do
    echo "  test:    $mod"
done

# --- Compile and run ---
BUILD_BIN="$ROOT/target/_ae_build_all"
"$AETHER" build "$GEN_FILE" -o "$BUILD_BIN" 2>&1 | grep -v 'warning:' || true
exec "$BUILD_BIN" "$ROOT"
