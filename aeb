#!/bin/bash
# aeb — Aether Build runner
# Scans .build.ae / .tests.ae / .dist.ae files (or takes an explicit .ae file),
# builds a unified DAG, topo-sorts, compiles each to C, links into one binary,
# and runs it. One process, one map, no subprocess coordination.
set -eo pipefail

AETHER="${AETHER:-ae}"
AEB_HOME="$(cd "$(dirname "$0")" && pwd)"
export AEB_HOME

# Auto-detect podman socket for TestContainers
if [[ -z "${DOCKER_HOST:-}" ]] && [[ -S "/run/user/$(id -u)/podman/podman.sock" ]]; then
    export DOCKER_HOST="unix:///run/user/$(id -u)/podman/podman.sock"
fi
ROOT="$(pwd)"
AEB_LIB=".aeb/lib"

# --- shipped modules (update this list when adding new SDKs) ---
SHIPPED_MODULES=(build java kotlin go rust ts scala clojure dotnet python container maven pnpm jest webpack angular)

# --- argument parsing ---
TARGET=""

if [[ "${1:-}" == "--init" ]]; then
    mkdir -p "$ROOT/$AEB_LIB"

    for mod in "${SHIPPED_MODULES[@]}"; do
        target="$AEB_HOME/lib/$mod"
        link="$ROOT/$AEB_LIB/$mod"
        if [[ -L "$link" ]]; then
            existing="$(readlink "$link")"
            if [[ "$existing" == "$target" ]]; then
                echo "  ok: $AEB_LIB/$mod"
            else
                rm "$link"
                ln -s "$target" "$link"
                echo "  updated: $AEB_LIB/$mod → $target"
            fi
        elif [[ -e "$link" ]]; then
            echo "  skip: $AEB_LIB/$mod (exists and is not a symlink)"
        else
            ln -s "$target" "$link"
            echo "  linked: $AEB_LIB/$mod → $target"
        fi
    done

    # update .gitignore
    gitignore="$ROOT/.gitignore"
    marker="# aetherBuild modules"
    if [[ -f "$gitignore" ]] && grep -qF "$marker" "$gitignore"; then
        echo "  .gitignore already configured"
    else
        {
            echo ""
            echo "$marker"
            echo ".aeb/"
        } >> "$gitignore"
        echo "  updated .gitignore"
    fi

    echo "aetherBuild initialized."
    exit 0
fi

# Parse remaining args
while [[ $# -gt 0 ]]; do
    case "$1" in
        *) TARGET="$1"; shift ;;
    esac
done
# Strip trailing slash
TARGET="${TARGET%/}"

# --- Encode file path to C-safe function name ---
# / → _    _ → __   - → _H_   . → _D_
encode_name() {
    echo "$1" | sed 's/__/\x00/g; s|/|_|g; s/-/_H_/g; s/\./_D_/g; s/\x00/__/g'
}

# --- Resolve a dep reference to a file path ---
# New-style: "path/to/.tests.ae" (ends in .ae) — used as-is
# Legacy:    "path/to/dir" — resolved to dir/.build.ae (or .tests.ae or .dist.ae)
resolve_dep() {
    local dep="$1"
    if [[ "$dep" == *.ae ]]; then
        echo "$dep"
        return
    fi
    # Legacy directory dep — find the .build.ae in that dir
    if [[ -f "./${dep}/.build.ae" ]]; then
        echo "${dep}/.build.ae"
    elif [[ -f "./${dep}/.tests.ae" ]]; then
        echo "${dep}/.tests.ae"
    elif [[ -f "./${dep}/.dist.ae" ]]; then
        echo "${dep}/.dist.ae"
    else
        echo "${dep}/.build.ae"  # pass through, will fail at compile time
    fi
}

# --- Infer file type from filename ---
# Used to determine the module_dir label prefix (test: / dist: / none)
infer_type() {
    local file="$1"
    case "$file" in
        *.tests.ae) echo "test" ;;
        *.dist.ae)  echo "dist" ;;
        *)          echo "build" ;;
    esac
}

# --- Derive module_dir from file path ---
# The runtime's build.begin() expects a directory path, optionally with test:/dist: prefix
file_to_label() {
    local file="$1"
    local type
    type=$(infer_type "$file")
    local dir
    dir=$(dirname "$file")
    case "$type" in
        test) echo "test:$dir" ;;
        dist) echo "dist:$dir" ;;
        *)    echo "$dir" ;;
    esac
}

# --- Unified DAG: scan or explicit ---
declare -A FILE_DEPS     # file_path → space-separated resolved dep file paths
declare -A FILE_EXISTS   # file_path → 1
ALL_AE_FILES=()

# Build exclusion list from .aebignore (one directory per line, like .gitignore)
IGNORE_EXCLUDES=(-not -path './target/*' -not -path './.aeb/*' -not -path './lib/*')
if [[ -f "$ROOT/.aebignore" ]]; then
    while IFS= read -r pattern; do
        [[ -z "$pattern" || "$pattern" == \#* ]] && continue
        pattern="${pattern%/}"
        IGNORE_EXCLUDES+=(-not -path "./${pattern}/*")
    done < "$ROOT/.aebignore"
fi

# Extract and resolve deps from a .ae file
extract_deps() {
    local file="$1"
    local raw_deps resolved_deps=""
    raw_deps="$(grep -oP '(?<=dep\(b, ")[^"]+' "$file" 2>/dev/null || true)"
    for dep in $raw_deps; do
        local resolved
        resolved=$(resolve_dep "$dep")
        resolved_deps+="$resolved "
    done
    echo "$resolved_deps"
}

if [[ -z "$TARGET" ]]; then
    # --- Scan mode: discover all .build.ae, .tests.ae, .dist.ae files ---
    for ae_file in $(find . \( -name '.build.ae' -o -name '.tests.ae' -o -name '.dist.ae' \) "${IGNORE_EXCLUDES[@]}" | sort); do
        file_path="${ae_file#./}"
        ALL_AE_FILES+=("$file_path")
        FILE_EXISTS["$file_path"]=1
        FILE_DEPS["$file_path"]="$(extract_deps "$ae_file")"
    done
else
    # --- Explicit target mode ---
    if [[ "$TARGET" == *.ae ]]; then
        # Explicit file: aeb path/to/whatever.ae
        if [[ ! -f "./$TARGET" ]]; then
            echo "error: $TARGET not found" >&2
            exit 1
        fi
    else
        # Legacy directory target: resolve to a file
        if [[ -f "./${TARGET}/.tests.ae" ]]; then
            TARGET="${TARGET}/.tests.ae"
        elif [[ -f "./${TARGET}/.build.ae" ]]; then
            TARGET="${TARGET}/.build.ae"
        elif [[ -f "./${TARGET}/.dist.ae" ]]; then
            TARGET="${TARGET}/.dist.ae"
        else
            echo "error: no .ae files found in $TARGET" >&2
            exit 1
        fi
    fi

    # BFS to discover the target and all transitive deps
    declare -a QUEUE=("$TARGET")
    declare -A SEEN
    SEEN["$TARGET"]=1
    local_i=0
    while (( local_i < ${#QUEUE[@]} )); do
        file="${QUEUE[$local_i]}"
        local_i=$(( local_i + 1 ))
        ALL_AE_FILES+=("$file")
        FILE_EXISTS["$file"]=1
        FILE_DEPS["$file"]="$(extract_deps "./$file")"
        for dep in ${FILE_DEPS[$file]}; do
            if [[ -z "${SEEN[$dep]+x}" ]] && [[ -f "./$dep" ]]; then
                SEEN["$dep"]=1
                QUEUE+=("$dep")
            fi
        done
    done
fi

if [ ${#ALL_AE_FILES[@]} -eq 0 ]; then
    echo "No .ae build files found"
    exit 0
fi

# --- Topological sort (unified, all file types) ---
declare -A VISITED
SORTED_FILES=()

visit() {
    local file="$1"
    [[ "${VISITED[$file]}" == "done" ]] && return
    if [[ "${VISITED[$file]}" == "visiting" ]]; then
        echo "error: circular dependency involving $file" >&2
        exit 1
    fi
    VISITED["$file"]="visiting"
    for dep in ${FILE_DEPS[$file]}; do
        if [[ -n "${FILE_EXISTS[$dep]+x}" ]]; then
            visit "$dep"
        fi
    done
    VISITED["$file"]="done"
    SORTED_FILES+=("$file")
}

for f in "${ALL_AE_FILES[@]}"; do
    visit "$f"
done

# --- Compile each .ae file separately, then link ---
AETHERC="${AETHER}therc"
if ! command -v "$AETHERC" &>/dev/null; then
    AETHERC="$(dirname "$(command -v "$AETHER")")/aetherc"
fi
BUILD_DIR="$ROOT/target/_aeb"
mkdir -p "$BUILD_DIR"

declare -A ALL_MODULES   # fname → module_dir
ALL_C_FILES=()

# Collect transitive imports from SDK modules.
# Given a source .ae file, find all imports, then scan those SDK modules
# for their own imports, and return any missing ones.
resolve_transitive_imports() {
    local src="$1"
    local -A seen=()
    local -a queue=()

    # Seed with direct imports from the source file
    while IFS= read -r mod; do
        [[ -n "$mod" ]] || continue
        seen["$mod"]=1
        queue+=("$mod")
    done < <(grep -oP '^import \K\w+' "$src" | sort -u)

    # BFS through SDK module imports
    local i=0
    while (( i < ${#queue[@]} )); do
        local cur="${queue[$i]}"
        i=$(( i + 1 ))
        local mod_file="$ROOT/$AEB_LIB/$cur/module.ae"
        [[ -f "$mod_file" ]] || continue
        while IFS= read -r dep; do
            [[ -n "$dep" ]] || continue
            if [[ -z "${seen[$dep]+x}" ]]; then
                seen["$dep"]=1
                queue+=("$dep")
            fi
        done < <(grep -oP '^import \K\w+' "$mod_file" | sort -u)
    done

    # Return transitive imports not already fully imported in the source file.
    local -A full_imports=()
    while IFS= read -r line; do
        [[ -n "$line" ]] && full_imports["$line"]=1
    done < <(grep -oP '^import \K\w+$' "$src")

    for mod in "${!seen[@]}"; do
        if [[ -z "${full_imports[$mod]+x}" ]]; then
            echo "$mod"
        fi
    done
    return 0
}

# Transform a .ae file: rename main(), replace build.start() with build.begin(),
# and inject transitive imports so the compiler can resolve cross-module calls.
transform_ae() {
    local src="$1" func_name="$2" label="$3" out="$4"
    local escaped_label
    escaped_label=$(echo "$label" | sed 's/\//\\\//g')
    sed -e "s/^main() {/${func_name}(s: ptr) {/" \
        -e "s/b = build\.start()/b = build.begin(s, \"${escaped_label}\")\n    if b == 0 { return 0 }/" \
        -e 's|dep(b, "\([^"]*\)/\.[^"/]*\.ae")|dep(b, "\1")|g' \
        "$src" > "$out"

    # Add transitive imports at the top of the file
    local extra
    extra=$(resolve_transitive_imports "$src")
    if [[ -n "$extra" ]]; then
        local imports=""
        while IFS= read -r mod; do
            imports+="import ${mod}"$'\n'
        done <<< "$extra"
        local tmp="${out}.tmp"
        printf '%s' "$imports" | cat - "$out" > "$tmp" && mv "$tmp" "$out"
    fi
}

# Count by type for display
n_build=0; n_test=0; n_dist=0
for f in "${SORTED_FILES[@]}"; do
    case "$(infer_type "$f")" in
        build) n_build=$(( n_build + 1 )) ;;
        test)  n_test=$(( n_test + 1 )) ;;
        dist)  n_dist=$(( n_dist + 1 )) ;;
    esac
done
echo "aeb: ${n_build} compile + ${n_dist} dist + ${n_test} test"

# Compile all targets in topo order
for file_path in "${SORTED_FILES[@]}"; do
    type=$(infer_type "$file_path")
    fname="$(encode_name "$file_path")"
    src="./${file_path}"
    ae_tmp="$BUILD_DIR/${fname}.ae"
    c_out="$BUILD_DIR/${fname}.c"
    label=$(file_to_label "$file_path")

    case "$type" in
        build) echo "  compile: $(dirname "$file_path")" ;;
        test)  echo "  test:    $(dirname "$file_path")" ;;
        dist)  echo "  dist:    $(dirname "$file_path")" ;;
    esac

    transform_ae "$src" "$fname" "$label" "$ae_tmp"
    "$AETHERC" --lib "$ROOT/$AEB_LIB" "$ae_tmp" "$c_out" 2>/dev/null

    ALL_C_FILES+=("$c_out")
    ALL_MODULES["$fname"]="$(dirname "$file_path")"
done

# --- Generate orchestrator .ae ---
ORCH_FILE="$BUILD_DIR/_orchestrator.ae"
GEN_ORCH="$AEB_HOME/tools/gen-orchestrator"
if [[ ! -x "$GEN_ORCH" ]]; then
    "$AETHER" build "$AEB_HOME/tools/gen-orchestrator.ae" -o "$GEN_ORCH" 2>/dev/null
fi
"$GEN_ORCH" "${SORTED_FILES[@]}" > "$ORCH_FILE"

# --- Compile orchestrator and link ---
ORCH_C="$BUILD_DIR/_orchestrator.c"
BUILD_BIN="$ROOT/target/_ae_build_all"

# Compile orchestrator .ae to .c
"$AETHERC" --lib "$ROOT/$AEB_LIB" "$ORCH_FILE" "$ORCH_C" 2>/dev/null

# Find Aether runtime
AETHER_DIR="$(dirname "$(command -v "$AETHER")")"
AETHER_LIB="$AETHER_DIR/libaether.a"

# Link everything: orchestrator + all module .c files + runtime
if [[ -f "$AETHER_LIB" ]]; then
    # Precompiled runtime available
    gcc -O2 -pipe -w "$ORCH_C" "${ALL_C_FILES[@]}" \
        -L"$AETHER_DIR" -laether \
        -o "$BUILD_BIN" -pthread -lm \
        -Wl,--allow-multiple-definition \
        2>&1 || true
else
    # Fall back to compiling runtime from source
    AETHER_ROOT="$(cd "$AETHER_DIR/.." && pwd)"
    gcc -O2 -pipe -w "$ORCH_C" "${ALL_C_FILES[@]}" \
        "$AETHER_ROOT"/runtime/*.c \
        -I"$AETHER_ROOT/runtime" \
        -o "$BUILD_BIN" -pthread -lm \
        -Wl,--allow-multiple-definition \
        2>&1 || true
fi

exec "$BUILD_BIN" "$ROOT"
