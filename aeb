#!/usr/bin/env bash
# aeb — Aether Build runner (thin trampoline)
#
# Sets up a few environment values that are awkward to compute from inside
# Aether (AETHER, AEB_HOME, ROOT, optional Podman socket), then execs the
# Aether-language entry point in tools/aeb-main. Everything else — argument
# parsing, scan/target-mode discovery, dep extraction, topo sort, per-file
# compile, orchestrator generation, gcc link, and final exec of the build
# binary — lives in tools/aeb-main.ae and the helper tools it shells out to.
#
# This script uses only POSIX-level bash features (no associative arrays,
# no `${var^^}` case magic) so it runs on macOS default bash 3.2 as well
# as on modern Linux bash 4/5.
set -eo pipefail

AETHER="${AETHER:-ae}"
AEB_HOME="$(cd "$(dirname "$0")" && pwd)"
export AEB_HOME
ROOT="$(pwd)"

# --- --version: print aeb version and underlying ae version ---
if [[ "${1:-}" == "--version" ]]; then
    echo "aeb 0.0.0-dev"
    "$AETHER" --version 2>/dev/null | head -1
    exit 0
fi

# Auto-detect podman socket for TestContainers
if [[ -z "${DOCKER_HOST:-}" ]] && [[ -S "/run/user/$(id -u)/podman/podman.sock" ]]; then
    export DOCKER_HOST="unix:///run/user/$(id -u)/podman/podman.sock"
fi

# --- --init: lazy-build and exec the init tool ---
if [[ "${1:-}" == "--init" ]]; then
    AEB_INIT_BIN="$AEB_HOME/tools/aeb-init"
    if [[ ! -x "$AEB_INIT_BIN" ]]; then
        "$AETHER" build "$AEB_HOME/tools/aeb-init.ae" -o "$AEB_INIT_BIN" 2>/dev/null
    fi
    exec "$AEB_INIT_BIN" "$AEB_HOME"
fi

# --- gcheckout: lazy-build and exec the sparse-checkout tool ---
# Routes `aeb gcheckout ...` to tools/gcheckout, which walks the .ae-file
# DAG and adds each visited module's directory to git sparse-checkout.
if [[ "${1:-}" == "gcheckout" ]]; then
    GCHECKOUT_BIN="$AEB_HOME/tools/gcheckout"
    if [[ ! -x "$GCHECKOUT_BIN" ]]; then
        "$AETHER" build "$AEB_HOME/tools/gcheckout.ae" -o "$GCHECKOUT_BIN" 2>/dev/null
    fi
    shift
    exec "$GCHECKOUT_BIN" "$@"
fi

# --- --watch: dev-loop wrapper, watches source dirs and re-runs aeb ---
# Composes with cache + affected-target detection: a save fires inotify
# (or fswatch on macOS), the changed paths flow through the
# affected-target walk, and only impacted targets rebuild — most of
# them cache-hit. gcheckout-aware: only watches dirs that actually
# exist on disk (sparse-checkout may have hidden some).
if [[ "${1:-}" == "--watch" ]]; then
    shift
    exec "$AEB_HOME/tools/aeb-watch" "$@"
fi

# --- Normal build: lazy-build and exec the main tool ---
AEB_MAIN_BIN="$AEB_HOME/tools/aeb-main"
if [[ ! -x "$AEB_MAIN_BIN" ]]; then
    "$AETHER" build "$AEB_HOME/tools/aeb-main.ae" -o "$AEB_MAIN_BIN" 2>/dev/null
fi
exec "$AEB_MAIN_BIN" "$AETHER" "$AEB_HOME" "$ROOT" "${1:-}" "${2:-}"
