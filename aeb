#!/bin/bash
# aeb — Aether Build runner
# Scans .build.ae and .tests.ae files, extracts deps, generates a single
# linked program, runs it. One process, one map, no subprocess coordination.
set -eo pipefail

AETHER="${AETHER:-ae}"
AEB_HOME="$(cd "$(dirname "$0")" && pwd)"
export AEB_HOME

# Auto-detect podman socket for TestContainers
if [[ -z "${DOCKER_HOST:-}" ]] && [[ -S "/run/user/$(id -u)/podman/podman.sock" ]]; then
    export DOCKER_HOST="unix:///run/user/$(id -u)/podman/podman.sock"
fi
ROOT="$(pwd)"
AEB_LIB=".aeb/lib"

# --- shipped modules (update this list when adding new SDKs) ---
SHIPPED_MODULES=(build java kotlin go rust ts container maven pnpm jest webpack angular)

# --- argument parsing ---
TARGET=""
FORCE_DIST=0

if [[ "${1:-}" == "--init" ]]; then
    mkdir -p "$ROOT/$AEB_LIB"

    for mod in "${SHIPPED_MODULES[@]}"; do
        target="$AEB_HOME/lib/$mod"
        link="$ROOT/$AEB_LIB/$mod"
        if [[ -L "$link" ]]; then
            existing="$(readlink "$link")"
            if [[ "$existing" == "$target" ]]; then
                echo "  ok: $AEB_LIB/$mod"
            else
                rm "$link"
                ln -s "$target" "$link"
                echo "  updated: $AEB_LIB/$mod → $target"
            fi
        elif [[ -e "$link" ]]; then
            echo "  skip: $AEB_LIB/$mod (exists and is not a symlink)"
        else
            ln -s "$target" "$link"
            echo "  linked: $AEB_LIB/$mod → $target"
        fi
    done

    # update .gitignore
    gitignore="$ROOT/.gitignore"
    marker="# aetherBuild modules"
    if [[ -f "$gitignore" ]] && grep -qF "$marker" "$gitignore"; then
        echo "  .gitignore already configured"
    else
        {
            echo ""
            echo "$marker"
            echo ".aeb/"
        } >> "$gitignore"
        echo "  updated .gitignore"
    fi

    echo "aetherBuild initialized."
    exit 0
fi

# Parse remaining args
while [[ $# -gt 0 ]]; do
    case "$1" in
        --dist) FORCE_DIST=1; shift ;;
        *) TARGET="$1"; shift ;;
    esac
done

# --- Encode module path to C-safe function name ---
# / → _    _ → __
encode_name() {
    echo "$1" | sed 's/__/\x00/g; s|/|_|g; s/-/_H_/g; s/\x00/__/g'
}

# --- Scan for .build.ae and .tests.ae files ---
declare -A BUILD_DEPS    # module_dir → deps (from .build.ae)
declare -A BUILD_FILES   # module_dir → 1 (exists marker)
declare -A TEST_DEPS     # module_dir → deps (from .tests.ae)
declare -A TEST_FILES    # module_dir → 1
declare -A DIST_FILES    # module_dir → 1
BUILD_MODULES=()
TEST_MODULES=()
DIST_MODULES=()

for build_file in $(find . -name '.build.ae' -not -path './target/*' -not -path './.aeb/*' -not -path './lib/*' | sort); do
    dir=$(dirname "$build_file")
    module_dir="${dir#./}"
    BUILD_MODULES+=("$module_dir")
    BUILD_DEPS["$module_dir"]="$(grep -oP '(?<=dep\(b, ")[^"]+' "$build_file" 2>/dev/null || true)"
    BUILD_FILES["$module_dir"]=1
done

for dist_file in $(find . -name '.dist.ae' -not -path './target/*' -not -path './.aeb/*' -not -path './lib/*' | sort); do
    dir=$(dirname "$dist_file")
    module_dir="${dir#./}"
    DIST_MODULES+=("$module_dir")
    DIST_FILES["$module_dir"]=1
done

for test_file in $(find . -name '.tests.ae' -not -path './target/*' -not -path './.aeb/*' -not -path './lib/*' | sort); do
    dir=$(dirname "$test_file")
    module_dir="${dir#./}"
    TEST_MODULES+=("$module_dir")
    TEST_DEPS["$module_dir"]="$(grep -oP '(?<=dep\(b, ")[^"]+' "$test_file" 2>/dev/null || true)"
    TEST_FILES["$module_dir"]=1
done

if [ ${#BUILD_MODULES[@]} -eq 0 ] && [ ${#TEST_MODULES[@]} -eq 0 ]; then
    echo "No .build.ae or .tests.ae files found"
    exit 0
fi

# --- Topological sort (build modules only, tests come after) ---
declare -A VISITED
SORTED_BUILD=()

visit() {
    local mod="$1"
    if [[ "${VISITED[$mod]}" == "done" ]]; then return; fi
    if [[ "${VISITED[$mod]}" == "visiting" ]]; then
        echo "error: circular dependency involving $mod" >&2
        exit 1
    fi
    VISITED["$mod"]="visiting"
    for dep in ${BUILD_DEPS[$mod]}; do
        if [[ -n "${BUILD_FILES[$dep]+x}" ]]; then
            visit "$dep"
        fi
    done
    VISITED["$mod"]="done"
    SORTED_BUILD+=("$mod")
}

for mod in "${BUILD_MODULES[@]}"; do
    visit "$mod"
done

# --- Target filtering ---
if [[ -n "$TARGET" ]]; then
    # Strip trailing slash
    TARGET="${TARGET%/}"

    # Collect transitive build deps of a module
    declare -A NEEDED_BUILD
    collect_build_deps() {
        local mod="$1"
        if [[ -n "${NEEDED_BUILD[$mod]+x}" ]]; then return; fi
        NEEDED_BUILD["$mod"]=1
        for dep in ${BUILD_DEPS[$mod]}; do
            if [[ -n "${BUILD_FILES[$dep]+x}" ]]; then
                collect_build_deps "$dep"
            fi
        done
    }

    # Auto-detect: what kind of target is this?
    IS_TEST=0
    IS_BUILD=0
    IS_DIST=0
    [[ -n "${TEST_FILES[$TARGET]+x}" ]] && IS_TEST=1
    [[ -n "${BUILD_FILES[$TARGET]+x}" ]] && IS_BUILD=1
    [[ -n "${DIST_FILES[$TARGET]+x}" ]] && IS_DIST=1

    if [[ $IS_TEST -eq 0 && $IS_BUILD -eq 0 && $IS_DIST -eq 0 ]]; then
        echo "error: no .build.ae, .tests.ae, or .dist.ae found for $TARGET" >&2
        exit 1
    fi

    if [[ $FORCE_DIST -eq 1 && $IS_DIST -eq 1 ]]; then
        # Explicit --dist: build + package (takes priority)
        collect_build_deps "$TARGET"
        FILTERED_BUILD=()
        for mod in "${SORTED_BUILD[@]}"; do
            if [[ -n "${NEEDED_BUILD[$mod]+x}" ]]; then
                FILTERED_BUILD+=("$mod")
            fi
        done
        SORTED_BUILD=("${FILTERED_BUILD[@]}")
        DIST_MODULES=("$TARGET")
        TEST_MODULES=()
    elif [[ $IS_TEST -eq 1 ]]; then
        # Test target: build its deps, then run the test
        for dep in ${TEST_DEPS[$TARGET]}; do
            if [[ -n "${BUILD_FILES[$dep]+x}" ]]; then
                collect_build_deps "$dep"
            fi
        done
        FILTERED_BUILD=()
        for mod in "${SORTED_BUILD[@]}"; do
            if [[ -n "${NEEDED_BUILD[$mod]+x}" ]]; then
                FILTERED_BUILD+=("$mod")
            fi
        done
        SORTED_BUILD=("${FILTERED_BUILD[@]}")
        TEST_MODULES=("$TARGET")
        DIST_MODULES=()
    else
        # Build target + deps
        collect_build_deps "$TARGET"
        FILTERED_BUILD=()
        for mod in "${SORTED_BUILD[@]}"; do
            if [[ -n "${NEEDED_BUILD[$mod]+x}" ]]; then
                FILTERED_BUILD+=("$mod")
            fi
        done
        SORTED_BUILD=("${FILTERED_BUILD[@]}")
        TEST_MODULES=()
        DIST_MODULES=()
    fi
fi

# --- Compile each module separately, then link ---
AETHERC="${AETHER}therc"
if ! command -v "$AETHERC" &>/dev/null; then
    AETHERC="$(dirname "$(command -v "$AETHER")")/aetherc"
fi
BUILD_DIR="$ROOT/target/_aeb"
mkdir -p "$BUILD_DIR"

# All .ae source files (build, test, dist) to compile
declare -A ALL_SOURCES   # fname → source .ae path
declare -A ALL_MODULES   # fname → module_dir
ALL_C_FILES=()

# Collect transitive imports from SDK modules.
# Given a source .ae file, find all imports, then scan those SDK modules
# for their own imports, and return any missing ones.
resolve_transitive_imports() {
    local src="$1"
    local -A seen=()
    local -a queue=()

    # Seed with direct imports from the source file
    while IFS= read -r mod; do
        [[ -n "$mod" ]] || continue
        seen["$mod"]=1
        queue+=("$mod")
    done < <(grep -oP '^import \K\w+' "$src" | sort -u)

    # BFS through SDK module imports
    local i=0
    while (( i < ${#queue[@]} )); do
        local cur="${queue[$i]}"
        i=$(( i + 1 ))
        local mod_file="$ROOT/$AEB_LIB/$cur/module.ae"
        [[ -f "$mod_file" ]] || continue
        while IFS= read -r dep; do
            [[ -n "$dep" ]] || continue
            if [[ -z "${seen[$dep]+x}" ]]; then
                seen["$dep"]=1
                queue+=("$dep")
            fi
        done < <(grep -oP '^import \K\w+' "$mod_file" | sort -u)
    done

    # Return transitive imports not already fully imported in the source file.
    # A selective import like "import maven (load_bom_file)" doesn't count —
    # the compiler needs a full "import maven" to resolve all cross-module calls.
    local -A full_imports=()
    while IFS= read -r line; do
        [[ -n "$line" ]] && full_imports["$line"]=1
    done < <(grep -oP '^import \K\w+$' "$src")

    for mod in "${!seen[@]}"; do
        if [[ -z "${full_imports[$mod]+x}" ]]; then
            echo "$mod"
        fi
    done
    return 0
}

# Transform a .ae file: rename main(), replace build.start() with build.begin(),
# and inject transitive imports so the compiler can resolve cross-module calls.
transform_ae() {
    local src="$1" func_name="$2" module_dir="$3" out="$4"
    local escaped_mod
    escaped_mod=$(echo "$module_dir" | sed 's/\//\\\//g')
    sed -e "s/^main() {/${func_name}(s: ptr) {/" \
        -e "s/b = build\.start()/b = build.begin(s, \"${escaped_mod}\")\n    if b == 0 { return 0 }/" \
        "$src" > "$out"

    # Add transitive imports at the top of the file
    local extra
    extra=$(resolve_transitive_imports "$src")
    if [[ -n "$extra" ]]; then
        local imports=""
        while IFS= read -r mod; do
            imports+="import ${mod}"$'\n'
        done <<< "$extra"
        # Prepend transitive imports before existing content
        local tmp="${out}.tmp"
        printf '%s' "$imports" | cat - "$out" > "$tmp" && mv "$tmp" "$out"
    fi
}

echo "aeb: ${#SORTED_BUILD[@]} compile + ${#DIST_MODULES[@]} dist + ${#TEST_MODULES[@]} test"

# Compile build targets
for mod in "${SORTED_BUILD[@]}"; do
    fname="build_$(encode_name "$mod")"
    src="./${mod}/.build.ae"
    ae_tmp="$BUILD_DIR/${fname}.ae"
    c_out="$BUILD_DIR/${fname}.c"

    echo "  compile: $mod"
    transform_ae "$src" "$fname" "$mod" "$ae_tmp"
    "$AETHERC" --lib "$ROOT/$AEB_LIB" "$ae_tmp" "$c_out" 2>/dev/null

    ALL_C_FILES+=("$c_out")
    ALL_MODULES["$fname"]="$mod"
done

# Compile test targets
for mod in "${TEST_MODULES[@]}"; do
    fname="test_$(encode_name "$mod")"
    src="./${mod}/.tests.ae"
    ae_tmp="$BUILD_DIR/${fname}.ae"
    c_out="$BUILD_DIR/${fname}.c"

    echo "  test:    $mod"
    transform_ae "$src" "$fname" "test:$mod" "$ae_tmp"
    "$AETHERC" --lib "$ROOT/$AEB_LIB" "$ae_tmp" "$c_out" 2>/dev/null

    ALL_C_FILES+=("$c_out")
    ALL_MODULES["$fname"]="$mod"
done

# Compile dist targets
for mod in "${DIST_MODULES[@]}"; do
    fname="dist_$(encode_name "$mod")"
    src="./${mod}/.dist.ae"
    ae_tmp="$BUILD_DIR/${fname}.ae"
    c_out="$BUILD_DIR/${fname}.c"

    echo "  dist:    $mod"
    transform_ae "$src" "$fname" "dist:$mod" "$ae_tmp"
    "$AETHERC" --lib "$ROOT/$AEB_LIB" "$ae_tmp" "$c_out" 2>/dev/null

    ALL_C_FILES+=("$c_out")
    ALL_MODULES["$fname"]="$mod"
done

# --- Generate orchestrator .ae ---
ORCH_FILE="$BUILD_DIR/_orchestrator.ae"
{
    echo "extern build_session(root: string) -> ptr"
    echo "extern build_done(s: ptr, module_dir: string)"
    echo "extern aether_args_get(index: int) -> string"
    echo ""

    # Extern declarations for all module functions
    for fname in "${!ALL_MODULES[@]}"; do
        echo "extern ${fname}(s: ptr) -> int"
    done
    echo ""

    # main() calls everything in order
    echo "main() {"
    echo "    s = build_session(aether_args_get(1))"

    # Build targets in topo order
    for mod in "${SORTED_BUILD[@]}"; do
        fname="build_$(encode_name "$mod")"
        echo "    ${fname}(s)"
        echo "    build_done(s, \"${mod}\")"
    done

    # Dist targets
    for mod in "${DIST_MODULES[@]}"; do
        fname="dist_$(encode_name "$mod")"
        echo "    ${fname}(s)"
        echo "    build_done(s, \"dist:${mod}\")"
    done

    # Test targets
    for mod in "${TEST_MODULES[@]}"; do
        fname="test_$(encode_name "$mod")"
        echo "    ${fname}(s)"
        echo "    build_done(s, \"test:${mod}\")"
    done

    echo "}"
} > "$ORCH_FILE"

# --- Compile orchestrator and link ---
ORCH_C="$BUILD_DIR/_orchestrator.c"
BUILD_BIN="$ROOT/target/_ae_build_all"

# Compile orchestrator .ae to .c
"$AETHERC" --lib "$ROOT/$AEB_LIB" "$ORCH_FILE" "$ORCH_C" 2>/dev/null

# Find Aether runtime
AETHER_DIR="$(dirname "$(command -v "$AETHER")")"
AETHER_LIB="$AETHER_DIR/libaether.a"

# Link everything: orchestrator + all module .c files + runtime
if [[ -f "$AETHER_LIB" ]]; then
    # Precompiled runtime available
    gcc -O2 -pipe -w "$ORCH_C" "${ALL_C_FILES[@]}" \
        -L"$AETHER_DIR" -laether \
        -o "$BUILD_BIN" -pthread -lm \
        -Wl,--allow-multiple-definition \
        2>&1 || true
else
    # Fall back to compiling runtime from source
    AETHER_ROOT="$(cd "$AETHER_DIR/.." && pwd)"
    gcc -O2 -pipe -w "$ORCH_C" "${ALL_C_FILES[@]}" \
        "$AETHER_ROOT"/runtime/*.c \
        -I"$AETHER_ROOT/runtime" \
        -o "$BUILD_BIN" -pthread -lm \
        -Wl,--allow-multiple-definition \
        2>&1 || true
fi

exec "$BUILD_BIN" "$ROOT"
