import std.string
import std.io
import std.os
import std.file
import std.fs
import std.list
import std.map
import std.path
import std.dir

import build
import maven
// Tests for junit_cmd()

import java
import java (junit_cmd)

_assert_eq(label: string, actual: string, expected: string) {
    if actual == expected {
        println("PASS: ${label}")
    } else {
        println("FAIL: ${label}")
        println("  expected: ${expected}")
        println("  actual:   ${actual}")
    }
}

main() {
    _assert_eq("no-config no-ldpath",
        junit_cmd("classes:deps.jar", "com.example.FooTests", "", null),
        "java -cp classes:deps.jar org.junit.runner.JUnitCore com.example.FooTests")

    _assert_eq("with ld_path",
        junit_cmd("classes", "com.example.FooTests", "/lib/native", null),
        "LD_LIBRARY_PATH=/lib/native java -Djava.library.path=/lib/native -cp classes org.junit.runner.JUnitCore com.example.FooTests")

    opts3 = map_new()
    map_put(opts3, "jvm_args", "-Xmx2g -ea")
    _assert_eq("jvm_args",
        junit_cmd("classes", "com.example.FooTests", "", opts3),
        "java -Xmx2g -ea -cp classes org.junit.runner.JUnitCore com.example.FooTests")

    opts4 = map_new()
    map_put(opts4, "jvm_args", "-Xmx4g")
    map_put(opts4, "extra", "-Dtest.env=ci")
    _assert_eq("ld_path+jvm_args+extra",
        junit_cmd("cp", "Tests", "/lib", opts4),
        "LD_LIBRARY_PATH=/lib java -Djava.library.path=/lib -Xmx4g -Dtest.env=ci -cp cp org.junit.runner.JUnitCore Tests")

    println("junit_cmd tests done")
}
