// Tests for the javac cache-key derivation in lib/java/module.ae.
//
// _cache_key_for_javac(ctx, b_map_map, argfile_path, cmd) reads
// .java sources via cache.hash_file and the dep artifacts via
// build._read_dep_artifact, so tests stage real fixtures under a
// tmpdir per case. Same shape as test_aether_cache.ae.
import std.string
import std.io
import std.os
import std.file
import std.fs
import std.list
import std.map
import std.path
import std.dir

import build
import java (_cache_key_for_javac, _jdk_version)

_assert_eq(label: string, actual: string, expected: string) {
    if actual == expected {
        println("PASS: ${label}")
    } else {
        println("FAIL: ${label}")
        println("  expected: '${expected}'")
        println("  actual:   '${actual}'")
    }
}

_assert_neq(label: string, a: string, b: string) {
    if a == b {
        println("FAIL: ${label}")
        println("  unexpected match: '${a}'")
    } else {
        println("PASS: ${label}")
    }
}

_assert_nonempty(label: string, s: string) {
    if string.length(s) > 0 {
        println("PASS: ${label}")
    } else {
        println("FAIL: ${label} (empty)")
    }
}

_mktempdir() {
    raw, _err = os.exec("mktemp -d")
    return string.trim(raw)
}

_write(path: string, content: string) {
    fs.write_atomic(path, content, string.length(content))
}

// Build a minimal ctx that satisfies _cache_key_for_javac's reads.
// It needs `deps` (a list, may be empty) and `root` for any
// _read_dep_artifact calls (we don't exercise that branch here).
_minimal_ctx(root: string) {
    ctx = map.new()
    map.put(ctx, "deps", list.new())
    map.put(ctx, "root", root)
    return ctx
}

main() {
    _assert_nonempty("jdk_version: non-empty", _jdk_version())

    tdir = _mktempdir()

    // Stage one Java source.
    src = path.join(tdir, "Hello.java")
    _write(src, "public class Hello {}\n")

    // Argfile lists the source.
    argfile = path.join(tdir, "argfile.txt")
    _write(argfile, string.concat(src, "\n"))

    ctx = _minimal_ctx(tdir)
    b_map = map.new()

    // --- determinism: same inputs → same key ---
    k1, e1 = _cache_key_for_javac(ctx, b_map, argfile, "javac -d /target -cp /target ${src}")
    _assert_eq("key: no error on fresh inputs", e1, "")
    _assert_nonempty("key: non-empty hash", k1)

    k2, _e2 = _cache_key_for_javac(ctx, b_map, argfile, "javac -d /target -cp /target ${src}")
    _assert_eq("determinism: same inputs → same key", k1, k2)

    // --- src content change → different key ---
    _write(src, "public class Hello { public static void f() {} }\n")
    k3, _e3 = _cache_key_for_javac(ctx, b_map, argfile, "javac -d /target -cp /target ${src}")
    _assert_neq("invalidation: src content change → different key", k1, k3)

    // --- restore content → original key ---
    _write(src, "public class Hello {}\n")
    k4, _e4 = _cache_key_for_javac(ctx, b_map, argfile, "javac -d /target -cp /target ${src}")
    _assert_eq("content-addressed: same content → same key", k1, k4)

    // --- cmd string change (e.g. flag added) → different key ---
    k_flag, _e5 = _cache_key_for_javac(ctx, b_map, argfile, "javac -d /target -cp /target -Xlint:all ${src}")
    _assert_neq("invalidation: cmd string change → different key", k1, k_flag)

    // --- adding a second source file → different key (different src list) ---
    src2 = path.join(tdir, "Other.java")
    _write(src2, "public class Other {}\n")
    argfile2 = path.join(tdir, "argfile2.txt")
    _write(argfile2, string.concat(string.concat(src, "\n"), string.concat(src2, "\n")))
    k_two, _e6 = _cache_key_for_javac(ctx, b_map, argfile2, "javac -d /target -cp /target ${src} ${src2}")
    _assert_neq("invalidation: extra .java added → different key", k1, k_two)

    // --- argfile order doesn't matter (sources sorted internally) ---
    argfile_rev = path.join(tdir, "argfile_rev.txt")
    _write(argfile_rev, string.concat(string.concat(src2, "\n"), string.concat(src, "\n")))
    // Same cmd string for both — only argfile differs, but contents
    // sort to the same order, so the key should match.
    k_two_rev, _e7 = _cache_key_for_javac(ctx, b_map, argfile_rev, "javac -d /target -cp /target ${src} ${src2}")
    _assert_eq("ordering: argfile listing order doesn't change key", k_two, k_two_rev)

    // --- missing src returns error, empty key ---
    bad_argfile = path.join(tdir, "bad.txt")
    _write(bad_argfile, string.concat(path.join(tdir, "nonexistent.java"), "\n"))
    k_bad, e_bad = _cache_key_for_javac(ctx, b_map, bad_argfile, "javac")
    _assert_eq("error path: missing src returns empty key", k_bad, "")
    _assert_nonempty("error path: missing src reports error", e_bad)

    os.system("rm -rf '${tdir}'")
    println("java cache-key tests done")
}
