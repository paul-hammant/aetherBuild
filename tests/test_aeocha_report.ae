// Tests for build._parse_aeocha_report.
//
// Pure parser — extracts (passed, failed, errored, failed_names,
// has_report) from the structured report Aeocha writes through
// std.ipc. Format reference: aeocha-aeb-ipc-reporting.md upstream ask.

import std.string
import std.io
import std.os
import std.file
import std.fs
import std.list
import std.map
import std.path
import std.dir

import build (_parse_aeocha_report)

extern println(s: string)

_assert_eq_int(label: string, actual: int, expected: int) {
    if actual == expected {
        println("PASS: ${label}")
    } else {
        println("FAIL: ${label}")
        println("  expected: ${expected}")
        println("  actual:   ${actual}")
    }
}

_assert_eq(label: string, actual: string, expected: string) {
    if actual == expected {
        println("PASS: ${label}")
    } else {
        println("FAIL: ${label}")
        println("  expected: '${expected}'")
        println("  actual:   '${actual}'")
    }
}

main() {
    // --- Empty input → no report ---
    p, f, e, names, h = _parse_aeocha_report("")
    _assert_eq_int("empty: passed", p, 0)
    _assert_eq_int("empty: failed", f, 0)
    _assert_eq_int("empty: errored", e, 0)
    _assert_eq("empty: failed_names", names, "")
    _assert_eq_int("empty: has_report", h, 0)

    // --- Hand-rolled-driver text (no version line) → no report ---
    junk = "this is not an aeocha report\nrandom output\n"
    p, f, e, names, h = _parse_aeocha_report(junk)
    _assert_eq_int("junk: has_report", h, 0)
    _assert_eq("junk: failed_names empty", names, "")

    // --- Canonical v1 report (header + rows) ---
    full = "version=1\ntotal=3\npassed=2\nfailed=1\nerrored=0\nduration_ms=42\n---\nPASS\t1\t\"first\"\t10\nFAIL\t2\t\"second\"\t20\texpected 1 got 2\nPASS\t3\t\"third\"\t5\n"
    p, f, e, names, h = _parse_aeocha_report(full)
    _assert_eq_int("full: passed",     p, 2)
    _assert_eq_int("full: failed",     f, 1)
    _assert_eq_int("full: errored",    e, 0)
    _assert_eq_int("full: has_report", h, 1)
    _assert_eq("full: failed_names with message", names, "second\texpected 1 got 2")

    // --- Header-only (no separator) — Aeocha's truncation fallback ---
    header_only = "version=1\ntotal=500\npassed=499\nfailed=1\nerrored=0\nduration_ms=99999\n"
    p, f, e, names, h = _parse_aeocha_report(header_only)
    _assert_eq_int("header-only: passed",     p, 499)
    _assert_eq_int("header-only: failed",     f, 1)
    _assert_eq_int("header-only: has_report", h, 1)
    _assert_eq("header-only: failed_names empty (no rows)", names, "")

    // --- Header with errored count + ERROR row ---
    with_err = "version=1\ntotal=5\npassed=3\nfailed=1\nerrored=1\nduration_ms=100\n---\nPASS\t1\t\"a\"\t10\nFAIL\t2\t\"b\"\t20\tboom\nERROR\t3\t\"c\"\t30\tcrash\nPASS\t4\t\"d\"\t40\nPASS\t5\t\"e\"\t50\n"
    p, f, e, names, h = _parse_aeocha_report(with_err)
    _assert_eq_int("with-err: passed",     p, 3)
    _assert_eq_int("with-err: failed",     f, 1)
    _assert_eq_int("with-err: errored",    e, 1)
    _assert_eq_int("with-err: has_report", h, 1)
    _assert_eq("with-err: both FAIL and ERROR collected", names,
        "b\tboom\nc\tcrash")

    // --- All passed → no failed_names ---
    all_pass = "version=1\ntotal=3\npassed=3\nfailed=0\nerrored=0\nduration_ms=200\n---\nPASS\t1\t\"a\"\t10\nPASS\t2\t\"b\"\t20\nPASS\t3\t\"c\"\t30\n"
    p, f, e, names, h = _parse_aeocha_report(all_pass)
    _assert_eq_int("all-pass: passed",     p, 3)
    _assert_eq_int("all-pass: failed",     f, 0)
    _assert_eq_int("all-pass: has_report", h, 1)
    _assert_eq("all-pass: failed_names empty", names, "")

    // --- Multiple failures, some with messages, some without ---
    multi = "version=1\ntotal=4\npassed=1\nfailed=3\nerrored=0\nduration_ms=400\n---\nFAIL\t1\t\"alpha\"\t10\tfirst failure\nFAIL\t2\t\"beta\"\t20\nPASS\t3\t\"gamma\"\t30\nFAIL\t4\t\"delta\"\t40\tlast failure\n"
    p, f, e, names, h = _parse_aeocha_report(multi)
    _assert_eq_int("multi: failed",     f, 3)
    _assert_eq("multi: 3 failed names, 2 with messages", names,
        "alpha\tfirst failure\nbeta\ndelta\tlast failure")

    // --- Unknown header keys ignored (forward compat) ---
    fwd = "version=1\nfuture_key=ignored\npassed=2\nfailed=0\nerrored=0\ntotal=2\nduration_ms=50\nnew_field=42\n---\n"
    p, f, e, names, h = _parse_aeocha_report(fwd)
    _assert_eq_int("fwd-compat: passed",     p, 2)
    _assert_eq_int("fwd-compat: has_report", h, 1)

    // --- Missing version still gates: no version → no report ---
    no_ver = "passed=5\nfailed=0\nerrored=0\ntotal=5\n---\n"
    p, f, e, names, h = _parse_aeocha_report(no_ver)
    _assert_eq_int("no-version: has_report", h, 0)
    _assert_eq("no-version: failed_names empty", names, "")

    // --- Trailing whitespace tolerated by string.to_int via trim ---
    ws = "version=1\npassed=  3  \nfailed=0\nerrored=0\ntotal=3\n---\n"
    p, f, e, names, h = _parse_aeocha_report(ws)
    _assert_eq_int("whitespace: passed", p, 3)

    // --- Failure with embedded tabs in message: only first tab is the
    // duration→message separator; remainder of the line stays in the
    // message verbatim. (Aeocha doesn't currently embed tabs, but we
    // shouldn't truncate if it ever does.)
    embedded = "version=1\ntotal=1\npassed=0\nfailed=1\nerrored=0\nduration_ms=10\n---\nFAIL\t1\t\"x\"\t10\tfoo\tbar\n"
    p, f, e, names, h = _parse_aeocha_report(embedded)
    _assert_eq("embedded-tab: message keeps tabs", names, "x\tfoo\tbar")

    println("aeocha report parser tests done")
}
