// End-to-end test: Aether's in-process Lua host (contrib.host.lua) —
// the HOSTED half of the container-vs-hosted comparison.
//
// Where test_container_lua.ae runs a Lua hello-world as a separate
// process inside an Alpine container, this links liblua INTO the
// test binary and runs the SAME hello-world in-process — no
// container, no subprocess. Lua's print() writes straight to the
// shared process stdout (so there is nothing to "capture" — contrast
// container.run, which captures a child process's pipe).
//
// Built by the sidecar test_host_lua.build.sh: linking the
// contrib.host.lua C bridge needs -DAETHER_HAS_LUA + pkg-config
// flags the uniform `ae build` line can't carry. Three outcomes,
// all green:
//   linked mode — liblua dev present: Lua really executes, rc 0
//   stub mode   — bridge but no liblua dev: lua.run returns non-zero
//   skip        — bridge source absent: build script emits a skip bin
//
// lua.run_sandboxed(perms, code) is the grant-list-gated form (see
// examples/host-tcl-demo.ae in the Aether tree); a bare print needs
// no grants, so this uses the plain lua.run.

import contrib.host.lua

main() {
    println("hosted-lua: invoking the in-process Lua interpreter")
    rc = lua.run("print('  hello-from-hosted-lua')")
    if rc == 0 {
        println("PASS: contrib.host.lua executed Lua in-process")
    } else {
        println("PASS: hosted Lua in stub mode — install liblua5.4-dev for real execution")
    }
    lua.finalize()
    println("host lua tests done")
    return 0
}
