// Tests for the pure helpers in tools/aeb-brew.ae.
//
// brew_formula_render is the renderer; class_name_from_output and
// _scan_quoted / _extract_first_arg / _extract_all_args do the
// text-extraction. All pure — no fs.
//
// Inlines the helpers because tests/run.sh builds with --lib lib/,
// and tools/ isn't on that path. Same pattern as test_aeb_graph.

import std.string
import std.io
import std.list

extern println(s: string)

// --- helpers under test (kept in lockstep with tools/aeb-brew.ae) ---

_upper_ascii(c: string) {
    if string.length(c) == 0 { return c }
    pairs = "abcdefghijklmnopqrstuvwxyz"
    upper = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
    n = string.length(pairs)
    i = 0
    while i < n {
        if string.equals(c, string.substring(pairs, i, i + 1)) == 1 {
            return string.substring(upper, i, i + 1)
        }
        i = i + 1
    }
    return c
}

class_name_from_output(name: string) {
    if string.length(name) == 0 { return "Formula" }
    out = ""
    rest = name
    while string.length(rest) > 0 {
        dash = string.index_of(rest, "-")
        word = ""
        if dash < 0 {
            word = rest
            rest = ""
        } else {
            word = string.substring(rest, 0, dash)
            rest = string.substring(rest, dash + 1, string.length(rest))
        }
        if string.length(word) > 0 {
            first = string.substring(word, 0, 1)
            tail = string.substring(word, 1, string.length(word))
            up = _upper_ascii(first)
            out = string.concat(out, up)
            out = string.concat(out, tail)
        }
    }
    return out
}

_scan_quoted(content: string, from: int) {
    n = string.length(content)
    p = from
    open_q = -1
    while p < n {
        c = string.substring(content, p, p + 1)
        if string.equals(c, "\"") == 1 {
            open_q = p
            p = n
        } else {
            p = p + 1
        }
    }
    if open_q < 0 { return "" }
    p = open_q + 1
    close_q = -1
    while p < n {
        c = string.substring(content, p, p + 1)
        if string.equals(c, "\"") == 1 {
            close_q = p
            p = n
        } else {
            p = p + 1
        }
    }
    if close_q < 0 { return "" }
    return string.substring(content, open_q + 1, close_q)
}

_extract_first_arg(content: string, fn_name: string) {
    qualified = string.concat(string.concat("meta.", fn_name), "(")
    bare      = string.concat(fn_name, "(")
    idx = string.index_of(content, qualified)
    needle_len = string.length(qualified)
    if idx < 0 {
        idx = string.index_of(content, bare)
        needle_len = string.length(bare)
    }
    if idx < 0 { return "" }
    p = idx + needle_len
    n = string.length(content)
    while p < n {
        c = string.substring(content, p, p + 1)
        if string.equals(c, ",") == 1 {
            p = p + 1
            return _scan_quoted(content, p)
        }
        if string.equals(c, ")") == 1 {
            return ""
        }
        p = p + 1
    }
    return ""
}

brew_formula_render(class_name: string, name: string, target_path: string,
                    desc: string, homepage: string, url_text: string,
                    sha256: string, license: string, version: string,
                    maintainers: string) {
    out = "# Generated by aeb --brew (do not edit; regenerate from .dist.ae)\n"
    out = string.concat(out, "class ")
    out = string.concat(out, class_name)
    out = string.concat(out, " < Formula\n")
    if string.length(desc) > 0 {
        out = string.concat(out, "  desc \"")
        out = string.concat(out, desc)
        out = string.concat(out, "\"\n")
    }
    if string.length(homepage) > 0 {
        out = string.concat(out, "  homepage \"")
        out = string.concat(out, homepage)
        out = string.concat(out, "\"\n")
    }
    if string.length(url_text) > 0 {
        out = string.concat(out, "  url \"")
        out = string.concat(out, url_text)
        out = string.concat(out, "\"\n")
    }
    if string.length(sha256) > 0 {
        out = string.concat(out, "  sha256 \"")
        out = string.concat(out, sha256)
        out = string.concat(out, "\"\n")
    }
    if string.length(license) > 0 {
        out = string.concat(out, "  license \"")
        out = string.concat(out, license)
        out = string.concat(out, "\"\n")
    }
    if string.length(version) > 0 {
        out = string.concat(out, "  version \"")
        out = string.concat(out, version)
        out = string.concat(out, "\"\n")
    }
    out = string.concat(out, "\n")
    out = string.concat(out, "  depends_on \"aeb\" => :build\n")
    out = string.concat(out, "\n")
    out = string.concat(out, "  def install\n")
    out = string.concat(out, "    system \"aeb\", \"")
    out = string.concat(out, target_path)
    out = string.concat(out, "\"\n")
    out = string.concat(out, "    bin.install \"target/")
    out = string.concat(out, name)
    out = string.concat(out, "/bin/")
    out = string.concat(out, name)
    out = string.concat(out, "\"\n")
    out = string.concat(out, "  end\n")
    out = string.concat(out, "\n")
    out = string.concat(out, "  test do\n")
    out = string.concat(out, "    # Placeholder smoke — refine to exercise real behaviour.\n")
    out = string.concat(out, "    system bin/\"")
    out = string.concat(out, name)
    out = string.concat(out, "\", \"--version\"\n")
    out = string.concat(out, "  end\n")
    out = string.concat(out, "end\n")
    return out
}

_assert_eq(label: string, actual: string, expected: string) {
    if actual == expected {
        println("PASS: ${label}")
    } else {
        println("FAIL: ${label}")
        println("  expected: '${expected}'")
        println("  actual:   '${actual}'")
    }
}

main() {
    // --- class_name_from_output ---
    _assert_eq("class: simple",       class_name_from_output("hello"),      "Hello")
    _assert_eq("class: hyphenated",   class_name_from_output("hello-world"), "HelloWorld")
    _assert_eq("class: triple",       class_name_from_output("a-b-c"),      "ABC")
    _assert_eq("class: empty fallback", class_name_from_output(""),         "Formula")
    _assert_eq("class: already cap",  class_name_from_output("Foo"),        "Foo")
    _assert_eq("class: with digits",  class_name_from_output("svn2git"),    "Svn2git")

    // --- _scan_quoted ---
    _assert_eq("scan_quoted: trivial",
        _scan_quoted("\"hello\"", 0), "hello")
    _assert_eq("scan_quoted: with leading space",
        _scan_quoted("   \"x\"", 0), "x")
    _assert_eq("scan_quoted: from offset past quote",
        _scan_quoted("\"a\" \"b\"", 4), "b")
    _assert_eq("scan_quoted: no quote → empty",
        _scan_quoted("foo", 0), "")
    _assert_eq("scan_quoted: empty literal",
        _scan_quoted("\"\"", 0), "")

    // --- _extract_first_arg: qualified meta.X(b, "...") form ---
    src1 = "meta.desc(b, \"a tiny tool\")"
    _assert_eq("extract: qualified desc",
        _extract_first_arg(src1, "desc"), "a tiny tool")

    // --- _extract_first_arg: bare X(b, "...") form (after `import meta (X)`) ---
    src2 = "desc(b, \"bare form works\")"
    _assert_eq("extract: bare desc",
        _extract_first_arg(src2, "desc"), "bare form works")

    // --- _extract_first_arg: prefer qualified to avoid shadow matches ---
    src3 = "// other.desc(x, \"WRONG\")\nmeta.desc(b, \"RIGHT\")"
    _assert_eq("extract: qualified takes precedence",
        _extract_first_arg(src3, "desc"), "RIGHT")

    // --- _extract_first_arg: missing returns empty ---
    _assert_eq("extract: missing → empty",
        _extract_first_arg("nothing here", "desc"), "")

    // --- _extract_first_arg: among many setters, picks the right one ---
    multi = "meta.desc(b, \"D\")\nmeta.url(b, \"U\")\nmeta.sha256(b, \"S\")"
    _assert_eq("extract: pick desc",     _extract_first_arg(multi, "desc"),   "D")
    _assert_eq("extract: pick url",      _extract_first_arg(multi, "url"),    "U")
    _assert_eq("extract: pick sha256",   _extract_first_arg(multi, "sha256"), "S")

    // --- brew_formula_render: minimal (only required fields) ---
    minimal = brew_formula_render("Hello", "hello", "lib/hello/.dist.ae",
                                  "", "",
                                  "https://example.com/hello.tgz",
                                  "abc123", "", "", "")
    expected_min = "# Generated by aeb --brew (do not edit; regenerate from .dist.ae)\nclass Hello < Formula\n  url \"https://example.com/hello.tgz\"\n  sha256 \"abc123\"\n\n  depends_on \"aeb\" => :build\n\n  def install\n    system \"aeb\", \"lib/hello/.dist.ae\"\n    bin.install \"target/hello/bin/hello\"\n  end\n\n  test do\n    # Placeholder smoke — refine to exercise real behaviour.\n    system bin/\"hello\", \"--version\"\n  end\nend\n"
    _assert_eq("render: minimal (url+sha256 only)", minimal, expected_min)

    // --- brew_formula_render: full (all fields) ---
    full = brew_formula_render("HelloWorld", "hello-world", "lib/hello/.dist.ae",
                               "Tiny greeter",
                               "https://example.com",
                               "https://example.com/hello.tgz",
                               "abc123", "MIT", "0.1.0", "")
    expected_full = "# Generated by aeb --brew (do not edit; regenerate from .dist.ae)\nclass HelloWorld < Formula\n  desc \"Tiny greeter\"\n  homepage \"https://example.com\"\n  url \"https://example.com/hello.tgz\"\n  sha256 \"abc123\"\n  license \"MIT\"\n  version \"0.1.0\"\n\n  depends_on \"aeb\" => :build\n\n  def install\n    system \"aeb\", \"lib/hello/.dist.ae\"\n    bin.install \"target/hello-world/bin/hello-world\"\n  end\n\n  test do\n    # Placeholder smoke — refine to exercise real behaviour.\n    system bin/\"hello-world\", \"--version\"\n  end\nend\n"
    _assert_eq("render: full (all fields)", full, expected_full)

    // --- brew_formula_render: omits empty optional sections ---
    no_desc = brew_formula_render("X", "x", "p.ae", "", "", "u", "s", "", "", "")
    has_desc_line = string.index_of(no_desc, "  desc ")
    if has_desc_line < 0 {
        println("PASS: render: empty desc → no desc line")
    } else {
        println("FAIL: render: empty desc still rendered desc line")
    }

    println("aeb-brew render tests done")
}
