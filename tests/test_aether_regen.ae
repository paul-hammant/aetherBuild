// Regression test: the --emit=lib regen pass re-runs when it should
// — on a source edit AND on a toolchain rebuild.
//
// avn filed cache_stale_prob.md claiming the regen pass is
// "toolchain-blind". It is not: 13e562b added a toolchain-mtime
// check to _run_regen_pass (the caller). The confusion came from
// reading _regen_action (the pure 2-arg helper) in isolation — it
// is deliberately mtime-only; the toolchain staleness is handled
// one level up. This test drives _run_regen_pass directly and pins
// all four outcomes so the behaviour can't silently regress.
//
// The "toolchain" is a wrapper script around the real aetherc so
// its mtime can be bumped without touching the installed binary.

import aether (_run_regen_pass)
import std.string
import std.os
import std.file
import std.list
import std.map

extern println(s: string)

_assert(label: string, cond: int) {
    if cond == 1 {
        println("PASS: ${label}")
    } else {
        println("FAIL: ${label}")
    }
}

main() {
    base = "/tmp/aeb_test_aether_regen"
    os.system("rm -rf ${base}; mkdir -p ${base}")

    // A minimal regen-able module (no imports → no --with= caps).
    os.system("printf 'foo() {\\n    return 1\\n}\\n' > ${base}/dep.ae")

    // Wrapper around the real aetherc — its mtime stands in for a
    // toolchain rebuild without disturbing the installed binary.
    aec_real, cerr = os.exec("command -v aetherc")
    aec_real = string.trim(aec_real)
    if string.equals(aec_real, "") == 1 {
        println("PASS: regen test skipped — aetherc not on PATH")
        println("aether regen tests done")
        return 0
    }
    aec = "${base}/aetherc-wrap"
    os.system("printf '#!/bin/sh\\nexec ${aec_real} \"$@\"\\n' > ${aec}; chmod +x ${aec}")

    genc = "${base}/dep_generated.c"

    bm = map.new()
    rl = list.new()
    _r1 = list.add(rl, "dep.ae")
    _r2 = map.put(bm, "regen", rl)
    caps = list.new()
    _r3 = list.add(caps, "")
    _r4 = map.put(bm, "regen_caps", caps)

    // 1. Fresh: the .c does not exist → regen produces it.
    rc1 = _run_regen_pass(bm, base, aec, "regen-test")
    m1 = file.mtime(genc)
    if rc1 != 0 {
        println("PASS: regen test skipped — aetherc --emit=lib unavailable")
        os.system("rm -rf ${base}")
        println("aether regen tests done")
        return 0
    }
    _assert("fresh: regen produced the generated .c", 1 - _eqi(m1, 0))

    // 2. Nothing changed → regen skips, .c mtime stays put.
    os.system("sleep 2")
    rc2 = _run_regen_pass(bm, base, aec, "regen-test")
    m2 = file.mtime(genc)
    _assert("unchanged inputs: regen skipped (mtime stable)", _eqi(m1, m2))

    // 3. Source edited → regen re-runs (the basic mtime-stale path).
    os.system("sleep 2; touch ${base}/dep.ae")
    rc3 = _run_regen_pass(bm, base, aec, "regen-test")
    m3 = file.mtime(genc)
    _assert("edited .ae source: regen re-ran", _gti(m3, m2))

    // 4. Toolchain rebuilt (aetherc newer than the .c, .ae unchanged)
    //    → regen re-runs. This is the 13e562b fix cache_stale_prob.md
    //    claimed was missing.
    os.system("sleep 2; touch ${aec}")
    rc4 = _run_regen_pass(bm, base, aec, "regen-test")
    m4 = file.mtime(genc)
    _assert("rebuilt toolchain: regen re-ran", _gti(m4, m3))

    os.system("rm -rf ${base}")
    println("aether regen tests done")
}

// int helpers (the test compares mtimes).
_eqi(a: int, b: int) {
    if a == b { return 1 }
    return 0
}
_gti(a: int, b: int) {
    if a > b { return 1 }
    return 0
}
