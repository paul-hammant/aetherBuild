import std.string
import std.io
import std.os
import std.file
import std.fs
import std.list
import std.map
import std.path
import std.dir

import build
import pnpm
// Tests for jest.jest_cmd()

import jest
import jest (jest_cmd)

_assert_eq(label: string, actual: string, expected: string) {
    if actual == expected {
        println("PASS: ${label}")
    } else {
        println("FAIL: ${label}")
        println("  expected: ${expected}")
        println("  actual:   ${actual}")
    }
}

main() {
    _assert_eq("jest_cmd basic 60s",
        jest_cmd("/proj/.aeb/.bin/jest", "/proj/apps/web/jest.config.ts", "60", null),
        "timeout 60 /proj/.aeb/.bin/jest --config '/proj/apps/web/jest.config.ts' --passWithNoTests")

    _assert_eq("jest_cmd 300s",
        jest_cmd("/n/jest", "/p/jest.config.ts", "300", null),
        "timeout 300 /n/jest --config '/p/jest.config.ts' --passWithNoTests")

    opts3 = map_new()
    map_put(opts3, "extra", "--coverage")
    _assert_eq("jest_cmd extra coverage",
        jest_cmd("/n/jest", "/p/cfg.ts", "60", opts3),
        "timeout 60 /n/jest --config '/p/cfg.ts' --passWithNoTests --coverage")

    opts4 = map_new()
    map_put(opts4, "extra", "--bail --maxWorkers=2")
    _assert_eq("jest_cmd multiple extra flags",
        jest_cmd("/n/jest", "/p/cfg.ts", "120", opts4),
        "timeout 120 /n/jest --config '/p/cfg.ts' --passWithNoTests --bail --maxWorkers=2")

    println("jest cmd tests done")
}
