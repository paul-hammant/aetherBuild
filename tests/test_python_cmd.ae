import std.string
import std.io
import std.os
import std.file
import std.fs
import std.list
import std.map
import std.path
import std.dir

import build
// Tests for python.pytest_cmd, python.ruff_lint_cmd, python.mypy_cmd,
// python.build_package_cmd, python.pip_install_cmd,
// python.pip_install_requirements_cmd

import python
import python (pytest_cmd, ruff_lint_cmd, mypy_cmd, build_package_cmd, pip_install_cmd, pip_install_requirements_cmd)

_assert_eq(label: string, actual: string, expected: string) {
    if actual == expected {
        println("PASS: ${label}")
    } else {
        println("FAIL: ${label}")
        println("  expected: ${expected}")
        println("  actual:   ${actual}")
    }
}

main() {
    _assert_eq("pytest_cmd basic",
        pytest_cmd("/v/bin/python", "/proj/src", "/proj"),
        "cd '/proj' && '/v/bin/python' -m pytest '/proj/src' -v")

    _assert_eq("ruff_lint_cmd basic",
        ruff_lint_cmd("/v/bin/ruff", "/proj/src"),
        "'/v/bin/ruff' check '/proj/src'")

    _assert_eq("mypy_cmd basic",
        mypy_cmd("/v/bin/python", "/proj/src", "/proj"),
        "cd '/proj' && '/v/bin/python' -m mypy '/proj/src' --ignore-missing-imports")

    _assert_eq("build_package_cmd basic",
        build_package_cmd("/v/bin/python", "/proj", "/proj/target/dist"),
        "cd '/proj' && '/v/bin/python' -m build --outdir '/proj/target/dist'")

    _assert_eq("pip_install_cmd basic",
        pip_install_cmd("/v/bin/pip", "requests==2.31.0"),
        "'/v/bin/pip' install -q 'requests==2.31.0'")

    _assert_eq("pip_install_cmd wheel path",
        pip_install_cmd("/v/bin/pip", "/lib/wheels/foo.whl"),
        "'/v/bin/pip' install -q '/lib/wheels/foo.whl'")

    _assert_eq("pip_install_requirements_cmd basic",
        pip_install_requirements_cmd("/v/bin/pip", "/proj/requirements.txt"),
        "'/v/bin/pip' install -q -r '/proj/requirements.txt'")

    println("python cmd tests done")
}
