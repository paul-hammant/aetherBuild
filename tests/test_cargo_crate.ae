import std.string
import std.io
import std.os
import std.file
import std.fs
import std.list
import std.map
import std.path
import std.dir

import build
// Tests for cargo_crate_toml_content() — workspace member crate Cargo.toml generation

import rust
import rust (cargo_crate_toml_content)

_assert_contains(label: string, actual: string, substring: string) {
    if string_contains(actual, substring) == 1 {
        println("PASS: ${label}")
    } else {
        println("FAIL: ${label}")
        println("  expected to contain: ${substring}")
        println("  actual: ${actual}")
    }
}

_assert_not_contains(label: string, actual: string, substring: string) {
    if string_contains(actual, substring) == 0 {
        println("PASS: ${label}")
    } else {
        println("FAIL: ${label}")
        println("  expected NOT to contain: ${substring}")
        println("  actual: ${actual}")
    }
}

_add_dep(opts: ptr, name: string, ver: string) {
    if map_has(opts, "_crate_deps") == 0 {
        map_put(opts, "_crate_deps", list_new())
    }
    deps, _ = map.get(opts, "_crate_deps")
    entry = string_concat(name, "~")
    entry = string_concat(entry, ver)
    list_add(deps, entry)
}

_add_dep_features(opts: ptr, name: string, ver: string, feats: string) {
    if map_has(opts, "_crate_deps_features") == 0 {
        map_put(opts, "_crate_deps_features", list_new())
    }
    deps, _ = map.get(opts, "_crate_deps_features")
    entry = string_concat(name, "~")
    entry = string_concat(entry, ver)
    entry = string_concat(entry, "~")
    entry = string_concat(entry, feats)
    list_add(deps, entry)
}

_add_path_dep(opts: ptr, name: string, p: string) {
    if map_has(opts, "_path_deps") == 0 {
        map_put(opts, "_path_deps", list_new())
    }
    deps, _ = map.get(opts, "_path_deps")
    entry = string_concat(name, "~")
    entry = string_concat(entry, p)
    list_add(deps, entry)
}

_add_ws_ref(opts: ptr, name: string) {
    if map_has(opts, "_ws_refs") == 0 {
        map_put(opts, "_ws_refs", list_new())
    }
    refs, _ = map.get(opts, "_ws_refs")
    list_add(refs, name)
}

_add_dev_ws_ref(opts: ptr, name: string) {
    if map_has(opts, "_dev_ws_refs") == 0 {
        map_put(opts, "_dev_ws_refs", list_new())
    }
    refs, _ = map.get(opts, "_dev_ws_refs")
    list_add(refs, name)
}

_add_bin(opts: ptr, name: string, p: string) {
    if map_has(opts, "_bins") == 0 {
        map_put(opts, "_bins", list_new())
    }
    bins, _ = map.get(opts, "_bins")
    entry = string_concat(name, "~")
    entry = string_concat(entry, p)
    list_add(bins, entry)
}

_add_feature(opts: ptr, name: string, deps_csv: string) {
    if map_has(opts, "_features") == 0 {
        map_put(opts, "_features", list_new())
    }
    feats, _ = map.get(opts, "_features")
    entry = string_concat(name, "~")
    entry = string_concat(entry, deps_csv)
    list_add(feats, entry)
}

main() {
    // --- Test 1: minimal — name only ---
    opts1 = map_new()
    map_put(opts1, "crate_name", "core")
    toml1 = cargo_crate_toml_content(opts1)
    _assert_contains("minimal has [package]", toml1, "[package]")
    _assert_contains("minimal has name", toml1, "name = \"core\"")
    _assert_not_contains("minimal no [lib]", toml1, "[lib]")
    _assert_not_contains("minimal no [dependencies]", toml1, "[dependencies]")

    // --- Test 2: edition.workspace = true ---
    opts2 = map_new()
    map_put(opts2, "crate_name", "lib")
    map_put(opts2, "edition", "2021")
    toml2 = cargo_crate_toml_content(opts2)
    _assert_contains("edition workspace inherit", toml2, "edition.workspace = true")

    // --- Test 3: explicit version ---
    opts3 = map_new()
    map_put(opts3, "crate_name", "app")
    map_put(opts3, "version", "1.0.0")
    toml3 = cargo_crate_toml_content(opts3)
    _assert_contains("explicit version", toml3, "version = \"1.0.0\"")

    // --- Test 4: [[bin]] section ---
    opts4 = map_new()
    map_put(opts4, "crate_name", "myapp")
    _add_bin(opts4, "myapp", "src/main.rs")
    toml4 = cargo_crate_toml_content(opts4)
    _assert_contains("[[bin]] header", toml4, "[[bin]]")
    _assert_contains("bin name", toml4, "name = \"myapp\"")
    _assert_contains("bin path", toml4, "path = \"src/main.rs\"")

    // --- Test 5: [lib] from crate_type ---
    opts5 = map_new()
    map_put(opts5, "crate_name", "shared")
    map_put(opts5, "crate_type", "cdylib")
    map_put(opts5, "lib_path", "src/lib.rs")
    toml5 = cargo_crate_toml_content(opts5)
    _assert_contains("[lib] header", toml5, "[lib]")
    _assert_contains("lib path", toml5, "path = \"src/lib.rs\"")
    _assert_contains("lib crate-type", toml5, "crate-type = [\"cdylib\"]")

    // --- Test 6: workspace ref dependency ---
    opts6 = map_new()
    map_put(opts6, "crate_name", "service")
    _add_ws_ref(opts6, "tokio")
    _add_ws_ref(opts6, "serde")
    toml6 = cargo_crate_toml_content(opts6)
    _assert_contains("[dependencies] header", toml6, "[dependencies]")
    _assert_contains("ws ref tokio", toml6, "tokio.workspace = true")
    _assert_contains("ws ref serde", toml6, "serde.workspace = true")

    // --- Test 7: direct version dep ---
    opts7 = map_new()
    map_put(opts7, "crate_name", "tool")
    _add_dep(opts7, "log", "0.4")
    toml7 = cargo_crate_toml_content(opts7)
    _assert_contains("direct version", toml7, "log = \"0.4\"")

    // --- Test 8: dep with features ---
    opts8 = map_new()
    map_put(opts8, "crate_name", "server")
    _add_dep_features(opts8, "tokio", "1.0", "full,macros")
    toml8 = cargo_crate_toml_content(opts8)
    _assert_contains("features dep", toml8, "tokio = { version = \"1.0\", features = [\"full\", \"macros\"] }")

    // --- Test 9: path dep ---
    opts9 = map_new()
    map_put(opts9, "crate_name", "app")
    _add_path_dep(opts9, "shared", "../shared")
    toml9 = cargo_crate_toml_content(opts9)
    _assert_contains("path dep", toml9, "shared = { path = \"../shared\" }")

    // --- Test 10: dev-dependencies ---
    opts10 = map_new()
    map_put(opts10, "crate_name", "lib")
    _add_dev_ws_ref(opts10, "proptest")
    toml10 = cargo_crate_toml_content(opts10)
    _assert_contains("dev-dependencies header", toml10, "[dev-dependencies]")
    _assert_contains("dev ws ref", toml10, "proptest.workspace = true")

    // --- Test 11: features section ---
    opts11 = map_new()
    map_put(opts11, "crate_name", "lib")
    map_put(opts11, "_default_features", "std,tls")
    _add_feature(opts11, "std", "")
    _add_feature(opts11, "tls", "openssl")
    toml11 = cargo_crate_toml_content(opts11)
    _assert_contains("features header", toml11, "[features]")
    _assert_contains("default features", toml11, "default = [\"std\", \"tls\"]")
    _assert_contains("empty feature", toml11, "std = []")
    _assert_contains("feature with deps", toml11, "tls = [\"openssl\"]")

    // --- Test 12: full combo (workspace member with mixed dep types) ---
    opts12 = map_new()
    map_put(opts12, "crate_name", "server-core")
    map_put(opts12, "edition", "2021")
    _add_ws_ref(opts12, "tokio")
    _add_dep(opts12, "log", "0.4")
    _add_dep_features(opts12, "serde", "1.0", "derive")
    _add_path_dep(opts12, "shared", "../shared")
    _add_dev_ws_ref(opts12, "proptest")
    toml12 = cargo_crate_toml_content(opts12)
    _assert_contains("combo: name", toml12, "name = \"server-core\"")
    _assert_contains("combo: ws inherit", toml12, "edition.workspace = true")
    _assert_contains("combo: ws ref", toml12, "tokio.workspace = true")
    _assert_contains("combo: direct dep", toml12, "log = \"0.4\"")
    _assert_contains("combo: features dep", toml12, "serde = { version = \"1.0\", features = [\"derive\"] }")
    _assert_contains("combo: path dep", toml12, "shared = { path = \"../shared\" }")
    _assert_contains("combo: dev-deps", toml12, "[dev-dependencies]")
    _assert_contains("combo: dev ws ref", toml12, "proptest.workspace = true")

    println("cargo_crate_toml_content tests done")
}
