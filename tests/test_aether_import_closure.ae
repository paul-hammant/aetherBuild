// Regression test: an aether.program target's cache key covers its
// transitive Aether `import` closure.
//
// The bug this guards: aeb's manual-path cache key
// (_cache_key_for_aether_link) used to hash only the entry .ae plus
// explicitly-declared extra_sources. A module reached via `import`
// — avn's repo_storage was the motivating case — was invisible, so
// editing it never busted a consumer's key and the consumer kept a
// stale binary. The key now walks the transitive import closure.
//
// Layout built below: app/main.ae imports `mid`, mid imports `deep`;
// `other` is an unrelated module nothing imports.

import aether (_cache_key_for_aether_link)
import std.string
import std.os

extern println(s: string)

_assert(label: string, cond: int) {
    if cond == 1 {
        println("PASS: ${label}")
    } else {
        println("FAIL: ${label}")
    }
}

main() {
    base = "/tmp/aeb_test_import_closure"
    os.system("rm -rf ${base}; mkdir -p ${base}/app ${base}/mid ${base}/deep ${base}/other")
    appdir = "${base}/app"
    entry = "${base}/app/main.ae"
    os.system("printf 'import mid\\nmain() {}\\n' > ${entry}")
    os.system("printf 'import deep\\nfoo() { return 1 }\\n' > ${base}/mid/module.ae")
    os.system("printf 'bar() { return 1 }\\n' > ${base}/deep/module.ae")
    os.system("printf 'unrelated() { return 1 }\\n' > ${base}/other/module.ae")

    k1, e1 = _cache_key_for_aether_link(null, appdir, entry, "/libx", "dup", "")
    // _cache_key_for_aether_link returns ("", err) when hashing is
    // unavailable (no OpenSSL/zlib) — skip cleanly in that case.
    if string.equals(e1, "") == 0 {
        println("PASS: import-closure test skipped — ${e1}")
        os.system("rm -rf ${base}")
        println("import closure tests done")
        return 0
    }

    k1b, _eb = _cache_key_for_aether_link(null, appdir, entry, "/libx", "dup", "")
    _assert("key is stable across recomputation", string.equals(k1, k1b))

    // Edit a TRANSITIVE import (deep ← mid ← app) — must bust the key.
    os.system("printf 'bar() { return 2 }\\n' > ${base}/deep/module.ae")
    k2, _e2 = _cache_key_for_aether_link(null, appdir, entry, "/libx", "dup", "")
    _assert("editing a transitive import busts the key", 1 - string.equals(k1, k2))

    // Edit a DIRECT import (mid) — must bust the key.
    os.system("printf 'import deep\\nfoo() { return 9 }\\n' > ${base}/mid/module.ae")
    k3, _e3 = _cache_key_for_aether_link(null, appdir, entry, "/libx", "dup", "")
    _assert("editing a direct import busts the key", 1 - string.equals(k2, k3))

    // Edit an UNRELATED module — nothing imports it — key must NOT move.
    os.system("printf 'unrelated() { return 7 }\\n' > ${base}/other/module.ae")
    k4, _e4 = _cache_key_for_aether_link(null, appdir, entry, "/libx", "dup", "")
    _assert("editing an unrelated module leaves the key unchanged", string.equals(k3, k4))

    os.system("rm -rf ${base}")
    println("import closure tests done")
}
