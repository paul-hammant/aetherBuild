// Regression test: an aether.program target's cache key covers the
// toolchain's *content*, not just its `ae --version` string.
//
// The bug this guards (filed by the avn project): `ae --version`
// reports the last release tag. A toolchain rebuilt from source
// between tags — e.g. with a codegen/typecheck fix landed as a HEAD
// commit — keeps the identical version string, so a version-string
// key gave a false cache hit and the consumer was never recompiled
// against the fixed compiler. _cache_key_for_aether_link now hashes
// the actual libaether.a (and aetherc binary) content.
//
// This exercises the libaether.a component with a synthetic archive;
// the aetherc-binary component is the identical cache.hash_file
// mechanism (the avn doc's manual procedure covers it end to end).

import aether (_cache_key_for_aether_link)
import std.string
import std.os

extern println(s: string)

_assert(label: string, cond: int) {
    if cond == 1 {
        println("PASS: ${label}")
    } else {
        println("FAIL: ${label}")
    }
}

main() {
    base = "/tmp/aeb_test_toolchain_key"
    os.system("rm -rf ${base}; mkdir -p ${base}/src ${base}/libdir")
    srcdir = "${base}/src"
    src = "${base}/src/main.ae"
    libdir = "${base}/libdir"
    os.system("printf 'main() {}\\n' > ${src}")
    os.system("printf 'fake-libaether-content-v1\\n' > ${libdir}/libaether.a")

    k1, e1 = _cache_key_for_aether_link(null, srcdir, src, libdir, "dup", "")
    // _cache_key_for_aether_link returns ("", err) when hashing is
    // unavailable (no OpenSSL/zlib) — skip cleanly in that case.
    if string.equals(e1, "") == 0 {
        println("PASS: toolchain-key test skipped — ${e1}")
        os.system("rm -rf ${base}")
        println("toolchain key tests done")
        return 0
    }

    k1b, _eb = _cache_key_for_aether_link(null, srcdir, src, libdir, "dup", "")
    _assert("key is stable across recomputation", string.equals(k1, k1b))

    // Simulate a toolchain rebuild: libaether.a content changes.
    os.system("printf 'fake-libaether-content-v2-rebuilt\\n' > ${libdir}/libaether.a")
    k2, _e2 = _cache_key_for_aether_link(null, srcdir, src, libdir, "dup", "")
    _assert("a rebuilt libaether.a busts the cache key", 1 - string.equals(k1, k2))

    // Restore the original content — key must return (content-addressed,
    // SHA256, not mtime: same bytes → same key despite a newer mtime).
    os.system("printf 'fake-libaether-content-v1\\n' > ${libdir}/libaether.a")
    k3, _e3 = _cache_key_for_aether_link(null, srcdir, src, libdir, "dup", "")
    _assert("restoring libaether.a content restores the key", string.equals(k1, k3))

    os.system("rm -rf ${base}")
    println("toolchain key tests done")
}
