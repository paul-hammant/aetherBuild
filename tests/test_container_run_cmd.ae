import std.string
import std.io
import std.os
import std.file
import std.fs
import std.list
import std.map
import std.path
import std.dir

import build
// Tests for container_run_cmd() — one-shot `<engine> run` command builder

import container
import container (container_run_cmd)

_assert_eq(label: string, actual: string, expected: string) {
    if actual == expected {
        println("PASS: ${label}")
    } else {
        println("FAIL: ${label}")
        println("  expected: ${expected}")
        println("  actual:   ${actual}")
    }
}

main() {
    // Default engine podman, no command
    _assert_eq("default engine, no command",
        container_run_cmd("alpine", null),
        "podman run --rm alpine")

    // With a command (appended as the container argv)
    opts1 = map_new()
    map_put(opts1, "command", "echo hi")
    _assert_eq("with command",
        container_run_cmd("ruby:alpine", opts1),
        "podman run --rm ruby:alpine echo hi")

    // Explicit docker engine
    opts2 = map_new()
    map_put(opts2, "engine", "docker")
    _assert_eq("docker engine",
        container_run_cmd("alpine", opts2),
        "docker run --rm alpine")

    // engine + command together
    opts3 = map_new()
    map_put(opts3, "engine", "docker")
    map_put(opts3, "command", "ls /")
    _assert_eq("docker engine + command",
        container_run_cmd("debian:slim", opts3),
        "docker run --rm debian:slim ls /")

    println("container_run_cmd tests done")
}
