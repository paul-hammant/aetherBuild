import std.string
import std.io
import std.os
import std.file
import std.fs
import std.list
import std.map
import std.path
import std.dir

import build
import pnpm
// Tests for angular.ngc_cmd, angular.ng_build_cmd

import angular
import angular (ngc_cmd, ng_build_cmd)

_assert_eq(label: string, actual: string, expected: string) {
    if actual == expected {
        println("PASS: ${label}")
    } else {
        println("FAIL: ${label}")
        println("  expected: ${expected}")
        println("  actual:   ${actual}")
    }
}

main() {
    _assert_eq("ngc_cmd basic",
        ngc_cmd("/n/.bin/ngc", "/proj/tsconfig.lib.json", null),
        "/n/.bin/ngc -p '/proj/tsconfig.lib.json'")

    opts2 = map_new()
    map_put(opts2, "skip_lib_check", "true")
    _assert_eq("ngc_cmd skip_lib_check",
        ngc_cmd("/n/ngc", "/p/tsconfig.json", opts2),
        "/n/ngc -p '/p/tsconfig.json' --skipLibCheck")

    opts3 = map_new()
    map_put(opts3, "extra", "--strictTemplates")
    _assert_eq("ngc_cmd extra",
        ngc_cmd("/n/ngc", "/p/tsconfig.json", opts3),
        "/n/ngc -p '/p/tsconfig.json' --strictTemplates")

    opts4 = map_new()
    map_put(opts4, "skip_lib_check", "true")
    map_put(opts4, "extra", "--strictTemplates")
    _assert_eq("ngc_cmd combined",
        ngc_cmd("/n/ngc", "/p/tsconfig.json", opts4),
        "/n/ngc -p '/p/tsconfig.json' --skipLibCheck --strictTemplates")

    _assert_eq("ng_build_cmd production",
        ng_build_cmd("/n/.bin/ng", "products", "production"),
        "/n/.bin/ng build products --configuration production")

    _assert_eq("ng_build_cmd development",
        ng_build_cmd("/n/ng", "ui", "development"),
        "/n/ng build ui --configuration development")

    println("angular cmd tests done")
}
