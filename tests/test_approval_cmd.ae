// Tests for lib/approval/module.ae's Jira approval script renderer.
//
// No live Jira server is required. We validate that the generated
// script references token env vars rather than literal tokens, calls
// Jira's REST API, exports requirements for the Python checker, and
// includes the requested go/no-go checks.

import std.string
import std.io
import std.os
import std.file
import std.fs
import std.list
import std.map
import std.path
import std.dir
import std.cryptography

import approval (jira_check_script, approval_json_check_script, canonicalize_attestation, attestation_evidence_json, _shell_quote)

extern println(s: string)

_assert_contains(label: string, haystack: string, needle: string) {
    if string.index_of(haystack, needle) >= 0 {
        println("PASS: ${label}")
    } else {
        println("FAIL: ${label}")
        println("  expected to find: '${needle}'")
    }
}

_assert_not_contains(label: string, haystack: string, needle: string) {
    if string.index_of(haystack, needle) < 0 {
        println("PASS: ${label}")
    } else {
        println("FAIL: ${label}")
        println("  did not expect: '${needle}'")
    }
}

_assert_eq(label: string, actual: string, expected: string) {
    if actual == expected {
        println("PASS: ${label}")
    } else {
        println("FAIL: ${label}")
        println("  expected: '${expected}'")
        println("  actual:   '${actual}'")
    }
}

main() {
    _assert_eq("shell quote simple", _shell_quote("abc"), "'abc'")
    _assert_eq("shell quote single quote", _shell_quote("a'b"), "'a'\\''b'")

    labels = list.new()
    list.add(labels, "release-approved")
    list.add(labels, "cab-ok")
    fields = list.new()
    list.add(fields, "Risk\tAccepted")
    list.add(fields, "customfield_123\tApproved")

    script = jira_check_script("https://jira.example.com", "REL-1234",
                               "JIRA_TOKEN", "Approved",
                               labels, fields,
                               "target/release-approval.json", "30")

    _assert_contains("sets base url", script, "BASE_URL='https://jira.example.com'")
    _assert_contains("sets issue", script, "ISSUE='REL-1234'")
    _assert_contains("uses token env name", script, "TOKEN_ENV='JIRA_TOKEN'")
    token_exp = "TOKEN=\"$"
    token_exp = string.concat(token_exp, "{!TOKEN_ENV:-}\"")
    _assert_contains("indirect token expansion", script, token_exp)
    _assert_not_contains("does not embed token value", script, "secret-token")
    issue_exp = "/rest/api/2/issue/$"
    issue_exp = string.concat(issue_exp, "{ISSUE}")
    _assert_contains("curl jira REST", script, issue_exp)
    _assert_contains("bearer header", script, "Authorization: Bearer $TOKEN")
    _assert_contains("exports requirements", script, "export REQUIRE_STATUS REQUIRE_LABELS REQUIRE_FIELDS")
    _assert_contains("requires status", script, "REQUIRE_STATUS='Approved'")
    _assert_contains("requires labels", script, "release-approved\ncab-ok")
    _assert_contains("requires fields", script, "Risk\tAccepted\ncustomfield_123\tApproved")
    _assert_contains("writes evidence", script, "json.dump(result, f, sort_keys=True)")
    _assert_contains("fails no-go", script, "approval.jira: NOT APPROVED")
    _assert_contains("success message", script, "approval.jira: approved")

    root = "/tmp/aeb-approval-test"
    os.system(string.concat("rm -rf ", root))
    os.system(string.concat("mkdir -p ", string.concat(root, "/bin")))
    fake_curl = "#!/usr/bin/env bash\nout=\"\"\nwhile [ $# -gt 0 ]; do\n  if [ \"$1\" = \"-o\" ]; then shift; out=\"$1\"; fi\n  shift || true\ndone\ncat > \"$out\" <<'JSON'\n{\"key\":\"REL-1234\",\"fields\":{\"status\":{\"name\":\"Approved\"},\"labels\":[\"release-approved\",\"cab-ok\"],\"Risk\":{\"value\":\"Accepted\"},\"customfield_123\":\"Approved\"}}\nJSON\n"
    curl_path = string.concat(root, "/bin/curl")
    fs.write_atomic(curl_path, fake_curl, string.length(fake_curl))
    os.system(string.concat("chmod +x ", curl_path))
    script_path = string.concat(root, "/check.sh")
    evidence_path = string.concat(root, "/evidence.json")
    run_script = jira_check_script("https://jira.example.com", "REL-1234",
                                   "JIRA_TOKEN", "Approved",
                                   labels, fields,
                                   evidence_path, "30")
    fs.write_atomic(script_path, run_script, string.length(run_script))
    os.system(string.concat("chmod +x ", script_path))
    cmd = string.concat("PATH=", string.concat(root, "/bin:$PATH JIRA_TOKEN=fake-token bash "))
    cmd = string.concat(cmd, script_path)
    run_out, run_err = os.exec(cmd)
    _assert_eq("fake jira execution stderr", string.trim(run_err), "")
    _assert_contains("fake jira execution approved", run_out, "approval.jira: approved REL-1234")
    evidence_body, _rerr = fs.read(evidence_path)
    _assert_contains("evidence ok true", evidence_body, "\"ok\": true")
    _assert_contains("evidence issue", evidence_body, "\"issue\": \"REL-1234\"")

    req_json = list.new()
    list.add(req_json, "change.status\tapproved")
    req_approvers = list.new()
    list.add(req_approvers, "person1")
    list.add(req_approvers, "person2")
    list.add(req_approvers, "person3")
    generic_json = "{\"change\":{\"status\":\"approved\"},\"approvals\":[{\"id\":\"person1\",\"approved_at\":\"2026-05-09T10:00:00Z\",\"status\":\"approved\"},{\"id\":\"person2\",\"approved_at\":\"2026-05-09T10:05:00Z\",\"status\":\"approved\"},{\"id\":\"person3\",\"approved_at\":\"2026-05-09T10:07:00Z\",\"status\":\"approved\"}]}\n"
    generic_src = string.concat(root, "/generic-response.json")
    generic_evidence = string.concat(root, "/generic-evidence.json")
    fs.write_atomic(generic_src, generic_json, string.length(generic_json))
    fetch_cmd = string.concat("cat ", string.concat(generic_src, " > \"$tmp\""))
    generic_script = approval_json_check_script("command", "release-1", fetch_cmd,
                                                req_json, req_approvers,
                                                "approvals", "id", "approved_at",
                                                "status", "approved",
                                                generic_evidence, "30")
    generic_script_path = string.concat(root, "/generic-check.sh")
    fs.write_atomic(generic_script_path, generic_script, string.length(generic_script))
    os.system(string.concat("chmod +x ", generic_script_path))
    generic_out, generic_err = os.exec(string.concat("bash ", generic_script_path))
    _assert_eq("generic approval stderr", string.trim(generic_err), "")
    _assert_contains("generic approval stdout", generic_out, "approval.command: approved release-1")
    generic_body, _gerr = fs.read(generic_evidence)
    _assert_contains("generic evidence person1", generic_body, "\"id\": \"person1\"")
    _assert_contains("generic evidence person2", generic_body, "\"id\": \"person2\"")
    _assert_contains("generic evidence person3", generic_body, "\"id\": \"person3\"")
    _assert_contains("generic evidence timestamp", generic_body, "\"approved_at\": \"2026-05-09T10:07:00Z\"")

    att_text = "Release: R-2026-05-09  \r\nChange: CHG123456\t\r\nperson1: approved at 2026-05-09T10:00:00Z\nperson2: approved at 2026-05-09T10:05:00Z\nperson3: approved at 2026-05-09T10:07:00Z\n\n\n"
    att_canon = "Release: R-2026-05-09\nChange: CHG123456\nperson1: approved at 2026-05-09T10:00:00Z\nperson2: approved at 2026-05-09T10:05:00Z\nperson3: approved at 2026-05-09T10:07:00Z\n"
    _assert_eq("attestation canonicalizes text", canonicalize_attestation(att_text), att_canon)
    verify_prefix = "https://verify.example.com/c"
    digest, derr = cryptography.sha256_hex(att_canon, string.length(att_canon))
    _assert_eq("attestation sha256 err", derr, "")
    att_url = string.concat(string.concat(verify_prefix, "/"), digest)
    att_body = attestation_evidence_json("attestation", "CHG123456", digest, att_url, att_canon)
    _assert_contains("attestation evidence hash", att_body, "\"attestation_sha256\":")
    _assert_contains("attestation evidence verify url", att_body, "\"verify_url\":\"https://verify.example.com/c/")
    _assert_contains("attestation evidence claim", att_body, "person3: approved at 2026-05-09T10:07:00Z")
}
