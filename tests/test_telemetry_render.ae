// Tests for the telemetry rendering helpers in lib/build/module.ae:
//   _format_telemetry_line(label, type, wall_ms, cache) → one summary line
//   render_telemetry(records, total_ms) → full summary block
//
// Both pure (no I/O); fixtures are synthetic record maps.
import std.string
import std.io
import std.os
import std.file
import std.fs
import std.list
import std.map
import std.path
import std.dir

import build (_format_telemetry_line, render_telemetry)

_assert_eq(label: string, actual: string, expected: string) {
    if actual == expected {
        println("PASS: ${label}")
    } else {
        println("FAIL: ${label}")
        println("  expected: '${expected}'")
        println("  actual:   '${actual}'")
    }
}

_record(lbl: string, type_word: string, wall_ms: int, cache: string) {
    r = map.new()
    map.put(r, "label", lbl)
    map.put(r, "type", type_word)
    map.put(r, "wall_ms", string.from_int(wall_ms))
    map.put(r, "cache", cache)
    return r
}

main() {
    // --- _format_telemetry_line: column widths + decimal seconds ---
    // type column is 8 chars (compile: + 1 pad), label column is 32.
    _assert_eq("line: compile / short label / 1.21s / miss",
        _format_telemetry_line("ae/svnserver", "compile", 1210, "miss", 0, 0, 0),
        "  compile: ae/svnserver                     1.21s [miss]")

    _assert_eq("line: test / short label / 0.01s / hit",
        _format_telemetry_line("ae/wc", "test", 10, "hit", 0, 0, 0),
        "  test:    ae/wc                            0.01s [hit]")

    _assert_eq("line: dist / 0.00s / n/a",
        _format_telemetry_line("dist:foo", "dist", 0, "n/a", 0, 0, 0),
        "  dist:    dist:foo                         0.00s [n/a]")

    // --- decimal-seconds rounding (cs = round(ms/10)) ---
    _assert_eq("line: 999ms rounds to 1.00s",
        _format_telemetry_line("x", "compile", 999, "miss", 0, 0, 0),
        "  compile: x                                1.00s [miss]")

    _assert_eq("line: 1000ms = 1.00s",
        _format_telemetry_line("x", "compile", 1000, "miss", 0, 0, 0),
        "  compile: x                                1.00s [miss]")

    _assert_eq("line: 1234ms = 1.23s",
        _format_telemetry_line("x", "compile", 1234, "miss", 0, 0, 0),
        "  compile: x                                1.23s [miss]")

    _assert_eq("line: 1235ms rounds to 1.24s",
        _format_telemetry_line("x", "compile", 1235, "miss", 0, 0, 0),
        "  compile: x                                1.24s [miss]")

    _assert_eq("line: 5ms = 0.01s (rounds up)",
        _format_telemetry_line("x", "compile", 5, "miss", 0, 0, 0),
        "  compile: x                                0.01s [miss]")

    _assert_eq("line: 4ms = 0.00s (rounds down)",
        _format_telemetry_line("x", "compile", 4, "miss", 0, 0, 0),
        "  compile: x                                0.00s [miss]")

    // --- long label exceeds padding column → no truncation, just no padding ---
    long_label = "ae/path/to/some/very/deep/module:with-tag"
    _assert_eq("line: long label flows past the 32-col pad",
        _format_telemetry_line(long_label, "compile", 100, "miss", 0, 0, 0),
        "  compile: ae/path/to/some/very/deep/module:with-tag 0.10s [miss]")

    // --- render_telemetry: full block ---
    records = list.new()
    list.add(records, _record("ae/svnserver",     "compile", 1210, "miss"))
    list.add(records, _record("ae/svnserver:seed","compile", 10,   "hit"))
    list.add(records, _record("ae/wc",            "test",    3030, "n/a"))

    expected_block = "[telemetry]\n  compile: ae/svnserver                     1.21s [miss]\n  compile: ae/svnserver:seed                0.01s [hit]\n  test:    ae/wc                            3.03s [n/a]\ntotal: 4.25s wall"
    _assert_eq("render: 3-record session", render_telemetry(records, 4250), expected_block)

    // --- empty records list (build with no targets) ---
    empty = list.new()
    _assert_eq("render: empty records",
        render_telemetry(empty, 0), "[telemetry]\ntotal: 0.00s wall")

    // --- single record ---
    one = list.new()
    list.add(one, _record("only", "compile", 500, "miss"))
    _assert_eq("render: single record",
        render_telemetry(one, 510),
        "[telemetry]\n  compile: only                             0.50s [miss]\ntotal: 0.51s wall")

    // --- _format_telemetry_line: with test-result trailer ---
    _assert_eq("line: test row with PASS trailer",
        _format_telemetry_line("ae/wc", "test", 3030, "n/a", 17, 0, 1),
        "  test:    ae/wc                            3.03s [n/a] 17/17 PASS")

    _assert_eq("line: test row with FAIL trailer (any failures → FAIL verdict)",
        _format_telemetry_line("ae/svn", "test", 5400, "n/a", 28, 2, 1),
        "  test:    ae/svn                           5.40s [n/a] 28/30 FAIL")

    _assert_eq("line: test row with all-fail trailer",
        _format_telemetry_line("flaky", "test", 100, "miss", 0, 5, 1),
        "  test:    flaky                            0.10s [miss] 0/5 FAIL")

    _assert_eq("line: test row with cache hit AND results",
        _format_telemetry_line("cached", "test", 50, "hit", 14, 0, 1),
        "  test:    cached                           0.05s [hit] 14/14 PASS")

    // has_test_result=0 → no trailer (fallback to no-results shape).
    _assert_eq("line: has_test_result=0 → no trailer",
        _format_telemetry_line("legacy", "test", 100, "n/a", 99, 99, 0),
        "  test:    legacy                           0.10s [n/a]")

    // --- render_telemetry: mixed records, some with results ---
    mixed = list.new()
    list.add(mixed, _record("ae/svnserver", "compile", 1210, "miss"))
    test_rec = _record("ae/wc", "test", 3030, "n/a")
    map.put(test_rec, "test_passed", "17")
    map.put(test_rec, "test_failed", "0")
    list.add(mixed, test_rec)
    fail_rec = _record("ae/svn", "test", 5400, "n/a")
    map.put(fail_rec, "test_passed", "28")
    map.put(fail_rec, "test_failed", "2")
    list.add(mixed, fail_rec)

    expected_mixed = "[telemetry]\n  compile: ae/svnserver                     1.21s [miss]\n  test:    ae/wc                            3.03s [n/a] 17/17 PASS\n  test:    ae/svn                           5.40s [n/a] 28/30 FAIL\ntotal: 9.64s wall"
    _assert_eq("render: mixed compile + 2 test records (one PASS, one FAIL)",
        render_telemetry(mixed, 9640), expected_mixed)

    // --- render_telemetry: FAIL row with test_failed_names → indented detail ---
    detailed = list.new()
    detail_rec = _record("ae/wc", "test", 5400, "n/a")
    map.put(detail_rec, "test_passed", "28")
    map.put(detail_rec, "test_failed", "2")
    map.put(detail_rec, "test_failed_names",
            "blame against demo\texpected 'alice' got 'bob'\nlog shows three commits\texit 1")
    list.add(detailed, detail_rec)
    expected_detail = "[telemetry]\n  test:    ae/wc                            5.40s [n/a] 28/30 FAIL\n          - blame against demo\texpected 'alice' got 'bob'\n          - log shows three commits\texit 1\ntotal: 5.40s wall"
    _assert_eq("render: FAIL row with detailed names indented",
        render_telemetry(detailed, 5400), expected_detail)

    // --- render_telemetry: PASS row with test_failed_names is unusual but
    // shouldn't render anything (failed=0 gates the detail block). ---
    paranoid = list.new()
    paranoid_rec = _record("ae/wc", "test", 100, "n/a")
    map.put(paranoid_rec, "test_passed", "5")
    map.put(paranoid_rec, "test_failed", "0")
    map.put(paranoid_rec, "test_failed_names", "stale data\nfrom previous run")
    list.add(paranoid, paranoid_rec)
    expected_paranoid = "[telemetry]\n  test:    ae/wc                            0.10s [n/a] 5/5 PASS\ntotal: 0.10s wall"
    _assert_eq("render: failed=0 gates detail block (no indented lines)",
        render_telemetry(paranoid, 100), expected_paranoid)

    // --- render_telemetry: FAIL row WITHOUT test_failed_names → no detail block ---
    nodetail = list.new()
    nodetail_rec = _record("ae/jest", "test", 200, "n/a")
    map.put(nodetail_rec, "test_passed", "3")
    map.put(nodetail_rec, "test_failed", "1")
    list.add(nodetail, nodetail_rec)
    expected_nodetail = "[telemetry]\n  test:    ae/jest                          0.20s [n/a] 3/4 FAIL\ntotal: 0.20s wall"
    _assert_eq("render: FAIL row without names → no detail block",
        render_telemetry(nodetail, 200), expected_nodetail)

    // --- render_telemetry: single failed name (no embedded message, no newline) ---
    single = list.new()
    single_rec = _record("ae/x", "test", 1000, "n/a")
    map.put(single_rec, "test_passed", "0")
    map.put(single_rec, "test_failed", "1")
    map.put(single_rec, "test_failed_names", "the only test")
    list.add(single, single_rec)
    expected_single = "[telemetry]\n  test:    ae/x                             1.00s [n/a] 0/1 FAIL\n          - the only test\ntotal: 1.00s wall"
    _assert_eq("render: single failed name, no message",
        render_telemetry(single, 1000), expected_single)

    println("telemetry render tests done")
}
