// Smoke tests for tools/aeb-query.ae as a command-line graph query tool.
//
// This builds the tool into /tmp, writes a fixture edges file, and
// exercises the public modes. It complements the pure helper tests in
// test_affected_targets.ae by testing the CLI parsing shapes:
// query deps(...), query rdeps(...), owners, path, why.

import std.string
import std.io
import std.os
import std.file
import std.fs
import std.list
import std.map
import std.path
import std.dir

extern println(s: string)

_assert_eq(label: string, actual: string, expected: string) {
    if actual == expected {
        println("PASS: ${label}")
    } else {
        println("FAIL: ${label}")
        println("  expected: '${expected}'")
        println("  actual:   '${actual}'")
    }
}

_run(cmd: string) {
    out, err = os.exec(cmd)
    if string.length(err) > 0 {
        return string.concat("ERR:", err)
    }
    return string.trim(out)
}

main() {
    tool = "/tmp/aeb-query-test"
    build_rc = os.system(string.concat("ae build tools/aeb-query.ae -o ", string.concat(tool, " >/dev/null 2>&1")))
    if build_rc != 0 {
        println("FAIL: build aeb-query")
        return 0
    }

    edges = ""
    edges = string.concat(edges, "apps/api/.dist.ae apps/api/.build.ae libs/core/.build.ae\n")
    edges = string.concat(edges, "apps/api/.build.ae libs/core/.build.ae libs/util/.build.ae\n")
    edges = string.concat(edges, "apps/api/.tests.ae apps/api/.build.ae libs/testkit/.build.ae\n")
    edges = string.concat(edges, "libs/core/.build.ae libs/util/.build.ae\n")
    edges = string.concat(edges, "libs/util/.build.ae \n")
    edges = string.concat(edges, "libs/testkit/.build.ae libs/util/.build.ae\n")
    edges_path = "/tmp/aeb-query-edges.txt"
    werr = io.write_file(edges_path, edges)
    if string.length(werr) > 0 {
        println("FAIL: write edges fixture")
        return 0
    }

    _assert_eq("deps transitive",
        _run(string.concat(tool, string.concat(" ", string.concat(edges_path, " query 'deps(apps/api/.dist.ae)'")))),
        "apps/api/.build.ae\nlibs/core/.build.ae\nlibs/util/.build.ae")

    _assert_eq("rdeps transitive",
        _run(string.concat(tool, string.concat(" ", string.concat(edges_path, " query 'rdeps(libs/util/.build.ae)'")))),
        "apps/api/.build.ae\napps/api/.dist.ae\napps/api/.tests.ae\nlibs/core/.build.ae\nlibs/testkit/.build.ae")

    _assert_eq("owners nearest dir",
        _run(string.concat(tool, string.concat(" ", string.concat(edges_path, " owners apps/api/src/main.go")))),
        "apps/api/.build.ae\napps/api/.dist.ae\napps/api/.tests.ae")

    _assert_eq("path",
        _run(string.concat(tool, string.concat(" ", string.concat(edges_path, " path apps/api/.dist.ae libs/util/.build.ae")))),
        "apps/api/.dist.ae\napps/api/.build.ae\nlibs/util/.build.ae")

    _assert_eq("why alias",
        _run(string.concat(tool, string.concat(" ", string.concat(edges_path, " why apps/api/.tests.ae libs/util/.build.ae")))),
        "apps/api/.tests.ae\napps/api/.build.ae\nlibs/util/.build.ae")
}
