// Tests for file_to_label() and extract_tag() — the label/tag
// derivation that disambiguates multiple .build*.ae / .tests*.ae /
// .dist*.ae files in the same directory.
//
// This imports the SAME `aeblabel` module that tools/file-to-label.ae,
// tools/gen-orchestrator.ae and tools/aeb-link.ae import. There is no
// inlined copy any more — the three former copies were consolidated
// into tools/aeblabel/module.ae, so this test exercises the exact
// code the build path runs. Drift is structurally impossible: there
// is only one implementation. (tests/run.sh builds with `--lib lib
// --lib tools` so the import resolves — multi-entry --lib, aether
// 0.150.)
import std.string

extern println(s: string)

import aeblabel (extract_tag, file_to_label)

_assert_eq(label: string, actual: string, expected: string) {
    if actual == expected {
        println("PASS: ${label}")
    } else {
        println("FAIL: ${label}")
        println("  expected: '${expected}'")
        println("  actual:   '${actual}'")
    }
}

main() {
    // --- extract_tag: basics ---
    _assert_eq("tag: canonical .build.ae",      extract_tag("ae/svnserver/.build.ae"),      "")
    _assert_eq("tag: canonical .tests.ae",      extract_tag("ae/svnserver/.tests.ae"),      "")
    _assert_eq("tag: canonical .dist.ae",       extract_tag("ae/svnserver/.dist.ae"),       "")
    _assert_eq("tag: .build-seed.ae",            extract_tag("ae/svnserver/.build-seed.ae"), "seed")
    _assert_eq("tag: .tests-int.ae",             extract_tag("ae/x/.tests-int.ae"),          "int")
    _assert_eq("tag: .dist-fat.ae",              extract_tag("ae/x/.dist-fat.ae"),           "fat")
    _assert_eq("tag: multi-word .build-foo-bar", extract_tag("ae/x/.build-foo-bar.ae"),      "foo-bar")
    _assert_eq("tag: bare .build.ae no dir",     extract_tag(".build.ae"),                    "")
    _assert_eq("tag: bare .build-seed.ae no dir",extract_tag(".build-seed.ae"),               "seed")
    _assert_eq("tag: not a build file",          extract_tag("ae/x/main.ae"),                "")
    _assert_eq("tag: no .ae extension",          extract_tag("ae/x/.build"),                  "")
    _assert_eq("tag: empty",                     extract_tag(""),                              "")

    // --- file_to_label: canonical names match historical behaviour ---
    _assert_eq("label: .build.ae", file_to_label("ae/svnserver/.build.ae"), "ae/svnserver")
    _assert_eq("label: .tests.ae", file_to_label("ae/svnserver/.tests.ae"), "test:ae/svnserver")
    _assert_eq("label: .dist.ae",  file_to_label("ae/svnserver/.dist.ae"),  "dist:ae/svnserver")
    _assert_eq("label: top-level .build.ae", file_to_label(".build.ae"),    ".")
    _assert_eq("label: deep path",            file_to_label("a/b/c/d/.build.ae"), "a/b/c/d")

    // --- file_to_label: tagged variants ---
    _assert_eq("label: .build-seed.ae",  file_to_label("ae/svnserver/.build-seed.ae"),
        "ae/svnserver:seed")
    _assert_eq("label: .tests-int.ae",   file_to_label("ae/x/.tests-int.ae"),
        "test:ae/x:int")
    _assert_eq("label: .dist-fat.ae",    file_to_label("ae/x/.dist-fat.ae"),
        "dist:ae/x:fat")
    _assert_eq("label: .build-foo-bar.ae",file_to_label("ae/x/.build-foo-bar.ae"),
        "ae/x:foo-bar")

    // --- the porter's exact failing case from round 218#4 ---
    _assert_eq("porter: .build.ae",
        file_to_label("ae/svnserver/.build.ae"), "ae/svnserver")
    _assert_eq("porter: .build-seed.ae",
        file_to_label("ae/svnserver/.build-seed.ae"), "ae/svnserver:seed")

    println("file_to_label tests done")
}
