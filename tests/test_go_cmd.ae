import build
// Tests for go_build_cmd() and go_test_cmd()

import go
import go (go_build_cmd, go_test_cmd)

_assert_eq(label: string, actual: string, expected: string) {
    if actual == expected {
        println("PASS: ${label}")
    } else {
        println("FAIL: ${label}")
        println("  expected: ${expected}")
        println("  actual:   ${actual}")
    }
}

main() {
    cmd1 = go_build_cmd("/src/mymod", "/out/lib/mymod.so", null)
    _assert_eq("build: no-config", cmd1,
        "cd /src/mymod && go build -o /out/lib/mymod.so")

    opts2 = map_new()
    map_put(opts2, "mode", "c-shared")
    map_put(opts2, "tags", "netgo")
    _assert_eq("build: mode+tags", go_build_cmd("/src", "/out/lib.so", opts2),
        "cd /src && go build -buildmode=c-shared -tags netgo -o /out/lib.so")

    opts3 = map_new()
    map_put(opts3, "ldflags", "-s -w")
    map_put(opts3, "race", "true")
    _assert_eq("build: ldflags+race", go_build_cmd("/src", "/out/bin", opts3),
        "cd /src && go build -ldflags \"-s -w\" -race -o /out/bin")

    opts4 = map_new()
    map_put(opts4, "env", "CGO_ENABLED=1")
    map_put(opts4, "mode", "c-shared")
    _assert_eq("build: env+mode", go_build_cmd("/src", "/out/lib.so", opts4),
        "cd /src && CGO_ENABLED=1 go build -buildmode=c-shared -o /out/lib.so")

    opts5 = map_new()
    map_put(opts5, "env", "CGO_ENABLED=1")
    map_put(opts5, "mode", "c-shared")
    map_put(opts5, "tags", "netgo")
    map_put(opts5, "ldflags", "-s -w")
    map_put(opts5, "race", "true")
    map_put(opts5, "extra", "-trimpath")
    _assert_eq("build: all combined", go_build_cmd("/src", "/out/lib.so", opts5),
        "cd /src && CGO_ENABLED=1 go build -buildmode=c-shared -tags netgo -ldflags \"-s -w\" -race -trimpath -o /out/lib.so")

    _assert_eq("test: no-config", go_test_cmd("/src", "", null),
        "cd /src && go test -v .")

    _assert_eq("test: ld_path", go_test_cmd("/src", "/lib/path", null),
        "cd /src && LD_LIBRARY_PATH=/lib/path go test -v .")

    opts8 = map_new()
    map_put(opts8, "verbose", "true")
    map_put(opts8, "race", "true")
    map_put(opts8, "run", "TestFoo")
    map_put(opts8, "timeout", "30s")
    _assert_eq("test: verbose+race+run+timeout", go_test_cmd("/src", "", opts8),
        "cd /src && go test -v -race -run TestFoo -timeout 30s .")

    println("go cmd tests done")
}
