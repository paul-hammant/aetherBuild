import std.string
import std.io
import std.os
import std.file
import std.fs
import std.list
import std.map
import std.path
import std.dir

import build
// Tests for maven.mvn_resolve_cmd()

import maven (mvn_resolve_cmd)

_assert_eq(label: string, actual: string, expected: string) {
    if actual == expected {
        println("PASS: ${label}")
    } else {
        println("FAIL: ${label}")
        println("  expected: ${expected}")
        println("  actual:   ${actual}")
    }
}

main() {
    // Empty everything
    _assert_eq("nothing — just resolver+output flag",
        mvn_resolve_cmd("/aeb/tools/aeb-resolve.jar", null, null, null, null),
        "java -jar /aeb/tools/aeb-resolve.jar --output classpath")

    // Only deps
    deps2 = list_new()
    list_add(deps2, "org.springframework.boot:spring-boot-starter:3.4.4")
    _assert_eq("single dep",
        mvn_resolve_cmd("/aeb/aeb-resolve.jar", null, null, null, deps2),
        "java -jar /aeb/aeb-resolve.jar --output classpath org.springframework.boot:spring-boot-starter:3.4.4")

    // Multiple deps
    deps3 = list_new()
    list_add(deps3, "org.apache.commons:commons-lang3:3.14.0")
    list_add(deps3, "com.google.guava:guava:33.0.0-jre")
    _assert_eq("multiple deps",
        mvn_resolve_cmd("/r.jar", null, null, null, deps3),
        "java -jar /r.jar --output classpath org.apache.commons:commons-lang3:3.14.0 com.google.guava:guava:33.0.0-jre")

    // BOM coords + deps (versions implied by BOM)
    boms4 = list_new()
    list_add(boms4, "org.springframework.boot:spring-boot-dependencies:3.4.4")
    deps4 = list_new()
    list_add(deps4, "org.springframework.data:spring-data-keyvalue")
    _assert_eq("bom + dep without version",
        mvn_resolve_cmd("/r.jar", null, boms4, null, deps4),
        "java -jar /r.jar --output classpath --bom org.springframework.boot:spring-boot-dependencies:3.4.4 org.springframework.data:spring-data-keyvalue")

    // BOM file
    bom_files5 = list_new()
    list_add(bom_files5, "/proj/.spring-boot.bom.ae")
    deps5 = list_new()
    list_add(deps5, "org.springframework:spring-core")
    _assert_eq("bom file",
        mvn_resolve_cmd("/r.jar", bom_files5, null, null, deps5),
        "java -jar /r.jar --output classpath --bom-file /proj/.spring-boot.bom.ae org.springframework:spring-core")

    // Custom repo
    repos6 = list_new()
    list_add(repos6, "https://artifactory.example.com/maven")
    deps6 = list_new()
    list_add(deps6, "com.example:lib:1.0")
    _assert_eq("custom repo",
        mvn_resolve_cmd("/r.jar", null, null, repos6, deps6),
        "java -jar /r.jar --output classpath --repo https://artifactory.example.com/maven com.example:lib:1.0")

    // Full combo: bom-file + bom + repo + deps
    bom_files7 = list_new()
    list_add(bom_files7, "/proj/.deps.bom.ae")
    boms7 = list_new()
    list_add(boms7, "org.spring:spring-bom:6.0")
    repos7 = list_new()
    list_add(repos7, "https://repo1.example.com")
    list_add(repos7, "https://repo2.example.com")
    deps7 = list_new()
    list_add(deps7, "org.foo:foo:1.0")
    list_add(deps7, "org.bar:bar:2.0")
    _assert_eq("full combo",
        mvn_resolve_cmd("/r.jar", bom_files7, boms7, repos7, deps7),
        "java -jar /r.jar --output classpath --bom-file /proj/.deps.bom.ae --bom org.spring:spring-bom:6.0 --repo https://repo1.example.com --repo https://repo2.example.com org.foo:foo:1.0 org.bar:bar:2.0")

    println("maven cmd tests done")
}
