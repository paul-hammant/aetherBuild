// Tests for lib/brew/module.ae's pure helpers and renderer.
//
// brew_formula_render is the renderer; _camelize, _basename, and
// _strip_dotbuild handle name munging. All pure — no fs.
//
// Imports from lib/brew directly (tests/run.sh builds with --lib lib/),
// no inlining.

import std.string
import std.io
import std.list
import brew (brew_formula_render, _camelize, _basename, _strip_dotbuild)

extern println(s: string)

_assert_eq(label: string, actual: string, expected: string) {
    if actual == expected {
        println("PASS: ${label}")
    } else {
        println("FAIL: ${label}")
        println("  expected: '${expected}'")
        println("  actual:   '${actual}'")
    }
}

main() {
    // --- _camelize ---
    _assert_eq("camelize: simple",     _camelize("hello"),       "Hello")
    _assert_eq("camelize: hyphenated", _camelize("hello-world"), "HelloWorld")
    _assert_eq("camelize: triple",     _camelize("a-b-c"),       "ABC")
    _assert_eq("camelize: empty fallback", _camelize(""),        "Formula")
    _assert_eq("camelize: already cap",   _camelize("Foo"),      "Foo")
    _assert_eq("camelize: with digits",   _camelize("svn2git"),  "Svn2git")

    // --- _basename ---
    _assert_eq("basename: nested path",   _basename("lib/hello/.build.ae"), ".build.ae")
    _assert_eq("basename: leaf only",     _basename("hello"),               "hello")
    _assert_eq("basename: trailing slash", _basename("foo/"),               "")
    _assert_eq("basename: empty",         _basename(""),                    "")

    // --- _strip_dotbuild ---
    _assert_eq("strip: .build.ae",  _strip_dotbuild(".build.ae"),  "build")
    _assert_eq("strip: .dist.ae",   _strip_dotbuild(".dist.ae"),   "dist")
    _assert_eq("strip: .foo.ae",    _strip_dotbuild(".foo.ae"),    "foo")
    _assert_eq("strip: no leading dot", _strip_dotbuild("foo.ae"), "foo")
    _assert_eq("strip: no .ae",     _strip_dotbuild(".foo"),       "foo")
    _assert_eq("strip: empty",      _strip_dotbuild(""),           "")

    // --- brew_formula_render: minimal (only required) ---
    minimal = brew_formula_render("Hello", "hello", "lib/hello/.build.ae",
                                  "", "",
                                  "https://example.com/hello.tgz",
                                  "abc123", "", "", "")
    expected_min = "# Generated by aeb (do not edit; regenerate via `aeb <.dist.ae>`)\nclass Hello < Formula\n  url \"https://example.com/hello.tgz\"\n  sha256 \"abc123\"\n\n  depends_on \"aeb\" => :build\n\n  def install\n    system \"aeb\", \"lib/hello/.build.ae\"\n    bin.install \"target/hello/bin/hello\"\n  end\n\n  test do\n    # Placeholder smoke — refine to exercise real behaviour.\n    system bin/\"hello\", \"--version\"\n  end\nend\n"
    _assert_eq("render: minimal", minimal, expected_min)

    // --- brew_formula_render: full ---
    full = brew_formula_render("HelloWorld", "hello-world", "lib/hello/.build.ae",
                               "Tiny greeter",
                               "https://example.com",
                               "https://example.com/hello.tgz",
                               "abc123", "MIT", "0.1.0", "")
    expected_full = "# Generated by aeb (do not edit; regenerate via `aeb <.dist.ae>`)\nclass HelloWorld < Formula\n  desc \"Tiny greeter\"\n  homepage \"https://example.com\"\n  url \"https://example.com/hello.tgz\"\n  sha256 \"abc123\"\n  license \"MIT\"\n  version \"0.1.0\"\n\n  depends_on \"aeb\" => :build\n\n  def install\n    system \"aeb\", \"lib/hello/.build.ae\"\n    bin.install \"target/hello-world/bin/hello-world\"\n  end\n\n  test do\n    # Placeholder smoke — refine to exercise real behaviour.\n    system bin/\"hello-world\", \"--version\"\n  end\nend\n"
    _assert_eq("render: full", full, expected_full)

    // --- brew_formula_render: custom test_assertion replaces the default ---
    with_test = brew_formula_render("X", "x", "p.ae", "", "", "u", "s", "", "",
                                    "assert_match \"x v1\", shell_output(\"#{bin}/x --version\")")
    has_default = string.index_of(with_test, "Placeholder smoke")
    has_custom  = string.index_of(with_test, "assert_match")
    if has_default < 0 {
        println("PASS: render: custom test replaces placeholder")
    } else {
        println("FAIL: render: custom test left the placeholder line in")
    }
    if has_custom >= 0 {
        println("PASS: render: custom test line is present")
    } else {
        println("FAIL: render: custom test line not in output")
    }

    // --- brew_formula_render: omits empty optional sections ---
    no_desc = brew_formula_render("X", "x", "p.ae", "", "", "u", "s", "", "", "")
    has_desc_line = string.index_of(no_desc, "  desc ")
    if has_desc_line < 0 {
        println("PASS: render: empty desc → no desc line")
    } else {
        println("FAIL: render: empty desc still rendered desc line")
    }

    println("brew render tests done")
}
